---
import '../styles/global.css';
import { anios } from '../lib/datos.js';

const {
  title,
  description,
  jsonLd = null,
  anioActivo = null,
  comparativaActiva = false,
  hermandadesActiva = false,
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site);
const anioActual = new Date().getFullYear();

const aniosAsc = [...anios].map((a) => a.anio).sort((x, y) => x - y);
const listaAnios = aniosAsc.length <= 1 ? String(aniosAsc[0] ?? '') : aniosAsc.slice(0, -1).join(', ') + ' y ' + aniosAsc.at(-1);
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <meta name="theme-color" content="#5b2a86" />
    <meta name="robots" content="index, follow" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Semana Santa Open Data" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:locale" content="es_ES" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="sitemap" href="/sitemap-index.xml" />

    {jsonLd && <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />}
    <slot name="head" />
  </head>
  <body>
    <a href="#main-content" class="saltar-contenido">Saltar al contenido</a>
    <header class="cabecera">
      <div class="contenedor cabecera__inner">
        <a href="/" class="marca"><span class="marca__punto" aria-hidden="true"></span> Semana Santa Open Data</a>
        <nav class="nav" aria-label="Principal">
          {anios.map((a) => {
            const esActivo = anioActivo === a.anio;
            return <a href={`/${a.slug}/`} class={esActivo ? 'activo' : ''} aria-current={esActivo ? 'page' : undefined}>{a.anio}</a>;
          })}
          <a href="/hermandades/" class={hermandadesActiva ? 'activo' : ''} aria-current={hermandadesActiva ? 'page' : undefined}>Hermandades</a>
          <a href="/comparativa/" class={comparativaActiva ? 'activo' : ''} aria-current={comparativaActiva ? 'page' : undefined}>Comparativa</a>
        </nav>
      </div>
    </header>

    <main id="main-content" tabindex="-1">
      <slot />
    </main>

    <footer class="pie">
      <div class="contenedor pie__inner">
        <div>
          <strong>Semana Santa Open Data</strong> — datos abiertos del conteo oficial de la Semana
          Santa de Sevilla. Tablas, gráficas y comparativa por año, día y hermandad, con descargas
          en CSV y JSON. Años disponibles: {listaAnios}.
        </div>
        <div>
          Datos transcritos de fuentes públicas (Consejo de Hermandades, prensa, hermandades).
          Cada página incluye sus fuentes. Este sitio no es oficial.
        </div>
        <div>
          Página creada por <a href="https://x.com/JaviWarSVQ" rel="noopener" target="_blank">@JaviWarSVQ<span class="visualmente-oculto"> (abre en nueva pestaña)</span></a>.
          · © {anioActual} · Proyecto de datos abiertos sin ánimo de lucro.
        </div>
      </div>
    </footer>
  </body>
</html>
