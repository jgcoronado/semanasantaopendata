---
const { registros, dias } = Astro.props;

const diasOrd = [...dias].sort((a, b) => a.orden - b.orden);

const COLORES_9 = ['#6929c4','#1192e8','#005d5d','#9f1853','#fa4d56','#198038','#b28600','#012749','#8a3800'];
const SIMBOLOS_3 = ['circle','triangle','rect'];

const estilosDias = diasOrd.map((d) => ({
  nombre: d.nombre,
  orden: d.orden,
  color: COLORES_9[(d.orden - 1) % 9],
  simbolo: SIMBOLOS_3[(d.orden - 1) % 3],
}));

const altoBarras = Math.max(220, registros.length * 13);

const datosCliente = {
  dias: diasOrd.map((d) => ({ slug: d.slug, nombre: d.nombre, orden: d.orden })),
  registros: registros.map((r) => ({
    nombre: r.nombre,
    diaSlug: r.diaSlug,
    diaOrden: r.diaOrden,
    tiempoPasoOficial:      r.tiempoPasoOficial,
    retrasoRealCampana:     r.retrasoRealCampana,
    tiempoPasoRealCampana:  r.tiempoPasoRealCampana,
    retrasoRealCatedral:    r.retrasoRealCatedral,
    tiempoPasoRealCatedral: r.tiempoPasoRealCatedral,
    tiempoRecortado:        r.tiempoRecortado,
    acumuladoCampana:       r.acumuladoCampana,
    acumuladoCatedral:      r.acumuladoCatedral,
    noNaz: r.noNaz,
  })),
};
---

<!-- ======================== EVOLUCIÓN ACUMULADO POR DÍA ======================== -->
<section class="panel contenedor" id="evolucion-acumulado">
  <div class="panel__cab"><h2>Evolución del acumulado</h2></div>
  <p class="panel__desc">
    Cómo crece (o mengua) el retraso acumulado de la jornada a medida que van pasando las hermandades
    por <strong>La Campana</strong> (línea sólida) y <strong>La Catedral</strong> (línea punteada).
  </p>
  <div class="controles">
    <label class="campo">Día <select id="sel-dia-acum">
      {diasOrd.map((d) => <option value={d.slug}>{d.nombre}</option>)}
    </select></label>
  </div>
  <figure class="grafica grafica--ancha">
    <figcaption>Acumulado por hermandad a lo largo del día (minutos)</figcaption>
    <div class="grafica__lienzo" style="height:240px">
      <canvas id="linea-acumulado" aria-label="Evolución del acumulado por día"></canvas>
    </div>
  </figure>
</section>

<!-- ======================== RETRASO REAL POR HERMANDAD ======================== -->
<section class="panel contenedor" id="retraso-sec">
  <div class="panel__cab"><h2>Retraso real individual</h2></div>
  <p class="panel__desc">
    Minutos que cada hermandad añadió (rojo) o recuperó (verde) al acumulado del día en
    <strong>La Campana</strong> y en <strong>La Catedral</strong>.
    Este es su contribución propia, descontando lo que ya acumulaban las hermandades anteriores.
  </p>
  <div class="controles">
    <label class="campo">Día <select id="sel-dia-retraso">
      {diasOrd.map((d) => <option value={d.slug}>{d.nombre}</option>)}
    </select></label>
  </div>
  <div class="graficas-grid">
    <figure class="grafica grafica--ancha">
      <figcaption>Retraso real en Campana (min por hermandad)</figcaption>
      <div class="grafica__lienzo" style={`height:${altoBarras}px`}>
        <canvas id="barras-retraso-campana" aria-label="Retraso real en Campana"></canvas>
      </div>
    </figure>
    <figure class="grafica grafica--ancha">
      <figcaption>Retraso real en Catedral (min por hermandad)</figcaption>
      <div class="grafica__lienzo" style={`height:${altoBarras}px`}>
        <canvas id="barras-retraso-catedral" aria-label="Retraso real en Catedral"></canvas>
      </div>
    </figure>
  </div>
</section>

<!-- ======================== DURACIÓN REAL VS OFICIAL ======================== -->
<section class="panel contenedor" id="duracion-sec">
  <div class="panel__cab"><h2>Duración real vs oficial por hermandad</h2></div>
  <p class="panel__desc">
    Comparativa entre la duración oficial de paso por La Campana (tiempo entre la cruz de guía y
    el último paso según el programa) y la duración real que tardaron en realidad, en Campana y en Catedral.
  </p>
  <div class="controles">
    <label class="campo">Día <select id="sel-dia-duracion">
      {diasOrd.map((d) => <option value={d.slug}>{d.nombre}</option>)}
    </select></label>
  </div>
  <figure class="grafica grafica--ancha">
    <figcaption>Duración oficial, real Campana y real Catedral por hermandad (min)</figcaption>
    <div class="grafica__lienzo" style={`height:${altoBarras}px`}>
      <canvas id="barras-duracion" aria-label="Duración real vs oficial"></canvas>
    </div>
  </figure>
</section>

<!-- ======================== GLOBAL ======================== -->
<section class="panel contenedor" id="global-carrera">
  <div class="panel__cab"><h2>Comparativa global</h2></div>

  <ul class="leyenda-dias" aria-label="Días procesionales">
    {estilosDias.map((e) => {
      const forma = e.simbolo === 'circle' ? 'circle' : e.simbolo === 'triangle' ? 'triangle' : 'rect';
      return (
        <li class="leyenda-dias__item">
          <svg width="18" height="18" viewBox="0 0 18 18" aria-hidden="true" style="flex-shrink:0">
            {forma === 'circle'   && <circle cx="9" cy="9" r="8" fill={e.color} />}
            {forma === 'triangle' && <polygon points="9,1 17,17 1,17" fill={e.color} />}
            {forma === 'rect'     && <rect x="1" y="1" width="16" height="16" rx="2" fill={e.color} />}
          </svg>
          <span>{e.nombre}</span>
        </li>
      );
    })}
  </ul>

  <figure class="grafica grafica--ancha" style="margin-top:1rem;margin-bottom:1.5rem">
    <figcaption>Nazarenos de la hermandad frente a su retraso real en Campana</figcaption>
    <div class="grafica__lienzo" style="height:280px">
      <canvas id="dispersion-retraso" aria-label="Nazarenos vs retraso real Campana"></canvas>
    </div>
  </figure>

  <figure class="grafica grafica--ancha">
    <figcaption>Acumulado final del día en Campana y Catedral (minutos al terminar el día)</figcaption>
    <div class="grafica__lienzo" style="height:220px">
      <canvas id="barras-acum-dia" aria-label="Acumulado final por día"></canvas>
    </div>
  </figure>
</section>

<script type="application/json" id="datos-carrera" set:html={JSON.stringify(datosCliente)}></script>
<script>
  import {
    Chart, BarController, BarElement, LineController, LineElement,
    PointElement, ScatterController, CategoryScale, LinearScale,
    Tooltip, Legend, Filler,
  } from 'chart.js';
  Chart.register(BarController, BarElement, LineController, LineElement, PointElement,
    ScatterController, CategoryScale, LinearScale, Tooltip, Legend, Filler);

  const datos = JSON.parse(document.getElementById('datos-carrera').textContent);

  const COLORES_9 = ['#6929c4','#1192e8','#005d5d','#9f1853','#fa4d56','#198038','#b28600','#012749','#8a3800'];
  const SIMBOLOS_3 = ['circle','triangle','rect'];
  const COLOR_POS = '#198038';
  const COLOR_NEG = '#da1e28';
  const COLOR_NEU = '#6b6776';

  const estiloDia = (orden) => ({ color: COLORES_9[(orden-1)%9], simbolo: SIMBOLOS_3[(orden-1)%3] });
  const fmtMin = (n) => {
    if (n == null) return '—';
    const abs = Math.abs(n);
    const h = Math.floor(abs/60), m = abs%60;
    const str = h > 0 ? `${h} h ${String(m).padStart(2,'0')} min` : `${m} min`;
    return (n > 0 ? '+' : n < 0 ? '−' : '') + str;
  };
  const durStr = (n) => {
    const abs = Math.abs(n), h = Math.floor(abs/60), m = abs%60;
    return h > 0 ? `${h} h ${String(m).padStart(2,'0')} min` : `${m} min`;
  };

  // Colores para barras positivo/negativo/neutro
  const colBar = (v, invert = false) =>
    v > 0 ? (invert ? COLOR_NEG : COLOR_POS) + 'cc'
  : v < 0 ? (invert ? COLOR_POS : COLOR_NEG) + 'cc'
  : COLOR_NEU + '88';
  const colBorder = (v, invert = false) =>
    v > 0 ? (invert ? COLOR_NEG : COLOR_POS)
  : v < 0 ? (invert ? COLOR_POS : COLOR_NEG)
  : COLOR_NEU;

  // ── Línea de acumulado por día ──
  const chartAcum = new Chart(document.getElementById('linea-acumulado'), {
    type: 'line',
    data: { labels: [], datasets: [] },
    options: {
      responsive: true, maintainAspectRatio: false,
      plugins: {
        legend: { display: true, position: 'top' },
        tooltip: { callbacks: {
          title: (items) => items[0]?.label ?? '',
          label: (c) => `${c.dataset.label}: ${fmtMin(c.raw)}`,
        }},
      },
      scales: {
        x: { ticks: { maxRotation: 45, autoSkip: false, font: { size: 10 } } },
        y: { title: { display: true, text: 'Minutos acumulados' },
             ticks: { callback: (v) => fmtMin(v) } },
      },
    },
  });

  function pintarAcumulado() {
    const slug = document.getElementById('sel-dia-acum').value;
    const regs = datos.registros.filter(r => r.diaSlug === slug);
    const diaInfo = datos.dias.find(d => d.slug === slug);
    const col = COLORES_9[(diaInfo.orden-1)%9];
    chartAcum.data.labels = regs.map(r => r.nombre);
    chartAcum.data.datasets = [
      { label: 'Acum. Campana', data: regs.map(r => r.acumuladoCampana),
        borderColor: col, backgroundColor: col+'22', borderWidth: 2,
        pointRadius: 4, pointHoverRadius: 6, tension: 0.25, fill: false },
      { label: 'Acum. Catedral', data: regs.map(r => r.acumuladoCatedral),
        borderColor: col, backgroundColor: col+'11', borderWidth: 2, borderDash: [6,4],
        pointRadius: 3, pointHoverRadius: 5, tension: 0.25, fill: false },
    ];
    chartAcum.update();
  }
  document.getElementById('sel-dia-acum').addEventListener('change', pintarAcumulado);
  pintarAcumulado();

  // ── Barras retraso real: Campana y Catedral ──
  const makeBarChart = (canvasId) => new Chart(document.getElementById(canvasId), {
    type: 'bar',
    data: { labels: [], datasets: [{ data: [], backgroundColor: [], borderColor: [], borderWidth: 1 }] },
    options: {
      indexAxis: 'y', responsive: true, maintainAspectRatio: false,
      plugins: { legend: { display: false },
        tooltip: { callbacks: {
          title: (items) => items[0]?.label ?? '',
          label: (c) => fmtMin(c.raw),
        }},
      },
      scales: {
        x: { title: { display: true, text: 'Minutos' }, ticks: { callback: (v) => fmtMin(v) } },
        y: { ticks: { autoSkip: false, font: { size: 10 } } },
      },
    },
  });

  const chartRetrasoCampana  = makeBarChart('barras-retraso-campana');
  const chartRetrasoCatedral = makeBarChart('barras-retraso-catedral');

  function pintarRetrasos() {
    const slug = document.getElementById('sel-dia-retraso').value;
    const regs = [...datos.registros.filter(r => r.diaSlug === slug)];

    // Campana: retraso > 0 es malo (más tiempo del programado)
    chartRetrasoCampana.data.labels = regs.map(r => r.nombre);
    chartRetrasoCampana.data.datasets[0].data = regs.map(r => r.retrasoRealCampana);
    chartRetrasoCampana.data.datasets[0].backgroundColor = regs.map(r => colBar(r.retrasoRealCampana, true));
    chartRetrasoCampana.data.datasets[0].borderColor     = regs.map(r => colBorder(r.retrasoRealCampana, true));
    chartRetrasoCampana.update();

    chartRetrasoCatedral.data.labels = regs.map(r => r.nombre);
    chartRetrasoCatedral.data.datasets[0].data = regs.map(r => r.retrasoRealCatedral);
    chartRetrasoCatedral.data.datasets[0].backgroundColor = regs.map(r => colBar(r.retrasoRealCatedral, true));
    chartRetrasoCatedral.data.datasets[0].borderColor     = regs.map(r => colBorder(r.retrasoRealCatedral, true));
    chartRetrasoCatedral.update();
  }
  document.getElementById('sel-dia-retraso').addEventListener('change', pintarRetrasos);
  pintarRetrasos();

  // ── Barras agrupadas: duración oficial vs real Campana vs real Catedral ──
  const chartDuracion = new Chart(document.getElementById('barras-duracion'), {
    type: 'bar',
    data: { labels: [], datasets: [
      { label: 'Dur. oficial',      data: [], backgroundColor: '#6b6776aa', borderColor: '#6b6776', borderWidth: 1 },
      { label: 'Dur. real Campana', data: [], backgroundColor: '#1192e8cc', borderColor: '#1192e8', borderWidth: 1 },
      { label: 'Dur. real Catedral',data: [], backgroundColor: '#9f1853cc', borderColor: '#9f1853', borderWidth: 1 },
    ]},
    options: {
      indexAxis: 'y', responsive: true, maintainAspectRatio: false,
      plugins: { legend: { position: 'top' },
        tooltip: { callbacks: {
          title: (items) => items[0]?.label ?? '',
          label: (c) => `${c.dataset.label}: ${durStr(c.raw)}`,
        }},
      },
      scales: {
        x: { title: { display: true, text: 'Minutos' }, ticks: { callback: (v) => durStr(v) } },
        y: { ticks: { autoSkip: false, font: { size: 10 } } },
      },
    },
  });

  function pintarDuracion() {
    const slug = document.getElementById('sel-dia-duracion').value;
    const regs = datos.registros.filter(r => r.diaSlug === slug);
    chartDuracion.data.labels = regs.map(r => r.nombre);
    chartDuracion.data.datasets[0].data = regs.map(r => r.tiempoPasoOficial);
    chartDuracion.data.datasets[1].data = regs.map(r => r.tiempoPasoRealCampana);
    chartDuracion.data.datasets[2].data = regs.map(r => r.tiempoPasoRealCatedral);
    chartDuracion.update();
  }
  document.getElementById('sel-dia-duracion').addEventListener('change', pintarDuracion);
  pintarDuracion();

  // ── Dispersión: nazarenos vs retraso real Campana ──
  const scatterDatasets = datos.dias
    .filter(d => datos.registros.some(r => r.diaSlug === d.slug && r.noNaz != null))
    .map(d => {
      const e = estiloDia(d.orden);
      return {
        label: d.nombre,
        data: datos.registros
          .filter(r => r.diaSlug === d.slug && r.noNaz != null)
          .map(r => ({ x: r.noNaz, y: r.retrasoRealCampana, nombre: r.nombre })),
        backgroundColor: e.color + 'bb', borderColor: e.color,
        pointStyle: e.simbolo, pointRadius: 7, pointHoverRadius: 9,
      };
    });

  new Chart(document.getElementById('dispersion-retraso'), {
    type: 'scatter',
    data: { datasets: scatterDatasets },
    options: {
      responsive: true, maintainAspectRatio: false,
      plugins: {
        legend: { position: 'bottom', labels: { usePointStyle: true, pointStyleWidth: 14, padding: 14 } },
        tooltip: { usePointStyle: true, callbacks: {
          title: (items) => items[0]?.raw?.nombre ?? '',
          label: (c) => `${c.raw.x.toLocaleString('es-ES')} naz. · Retraso: ${fmtMin(c.raw.y)}`,
        }},
      },
      scales: {
        x: { title: { display: true, text: 'Nazarenos' }, beginAtZero: true },
        y: { title: { display: true, text: 'Retraso real Campana (min)' },
             ticks: { callback: (v) => fmtMin(v) } },
      },
    },
  });

  // ── Barras agrupadas: acumulado final por día ──
  const acumPorDia = datos.dias.map(d => {
    const regsDelDia = datos.registros.filter(r => r.diaSlug === d.slug);
    const ultimo = regsDelDia[regsDelDia.length - 1];
    return { nombre: d.nombre, orden: d.orden,
             campana: ultimo?.acumuladoCampana ?? 0, catedral: ultimo?.acumuladoCatedral ?? 0 };
  });

  new Chart(document.getElementById('barras-acum-dia'), {
    type: 'bar',
    data: {
      labels: acumPorDia.map(d => d.nombre),
      datasets: [
        { label: 'Acum. Campana (final)',
          data: acumPorDia.map(d => d.campana),
          backgroundColor: acumPorDia.map(d => COLORES_9[(d.orden-1)%9]+'cc'),
          borderColor:     acumPorDia.map(d => COLORES_9[(d.orden-1)%9]),
          borderWidth: 1 },
        { label: 'Acum. Catedral (final)',
          data: acumPorDia.map(d => d.catedral),
          backgroundColor: acumPorDia.map(d => COLORES_9[(d.orden-1)%9]+'66'),
          borderColor:     acumPorDia.map(d => COLORES_9[(d.orden-1)%9]),
          borderWidth: 1, borderDash: [4,3] },
      ],
    },
    options: {
      responsive: true, maintainAspectRatio: false,
      plugins: { legend: { position: 'top' },
        tooltip: { callbacks: { label: (c) => `${c.dataset.label}: ${fmtMin(c.raw)}` } },
      },
      scales: {
        x: { ticks: { maxRotation: 35, font: { size: 10 } } },
        y: { title: { display: true, text: 'Minutos acumulados' },
             ticks: { callback: (v) => fmtMin(v) } },
      },
    },
  });
</script>
