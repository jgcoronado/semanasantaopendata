---
import { getAnio } from '../lib/datos.js';

const { anio } = Astro.props;
const { registros, totalesPorDia, diasPresentes } = getAnio(anio);

const datosGraficas = {
  dias: totalesPorDia.map((t) => ({ slug: t.slug, nombre: t.nombre, orden: t.orden, noNaz: t.noNaz, noTotal: t.noTotal })),
  hermandades: registros.map((r) => ({
    slug: r.slug,
    nombre: r.nombre,
    diaSlug: r.diaSlug,
  })),
};

const hermandadesDe = (slug) => registros.filter((r) => r.diaSlug === slug);
---

<section class="panel contenedor" id="graficas">
  <div class="panel__cab">
    <h2>Participantes por día</h2>
  </div>

  <div class="controles">
    <label class="campo">
      Resaltar hermandad
      <select id="selector-hermandad">
        <option value="">— Ninguna —</option>
        {diasPresentes.map((d) => (
          <optgroup label={d.nombre}>
            {hermandadesDe(d.slug).map((h) => <option value={h.slug}>{h.nombre}</option>)}
          </optgroup>
        ))}
      </select>
    </label>
  </div>

  <div class="graficas-grid">
    <figure class="grafica grafica--ancha">
      <figcaption>Nazarenos y cortejo total por día</figcaption>
      <div class="grafica__lienzo"><canvas id="grafica-dias" aria-hidden="true"></canvas></div>
      <p class="grafica__nota visualmente-oculto">Gráfica de barras con los totales de nazarenos y del cortejo por cada día procesional. Los datos completos están disponibles en la tabla de esta página.</p>
    </figure>
  </div>

  <script type="application/json" id="datos-graficas" set:html={JSON.stringify(datosGraficas)}></script>
</section>

<script>
  import { Chart, BarController, BarElement, CategoryScale, LinearScale, Tooltip, Legend } from 'chart.js';
  Chart.register(BarController, BarElement, CategoryScale, LinearScale, Tooltip, Legend);

  const datos = JSON.parse(document.getElementById('datos-graficas').textContent);
  const noAnim = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  const COLORES_9 = ['#6929c4','#1192e8','#005d5d','#9f1853','#fa4d56','#198038','#b28600','#012749','#8a3800'];
  const TINTA = '#1c1a22';
  const nf = new Intl.NumberFormat('es-ES', { useGrouping: 'always' });

  const colDia = (orden) => COLORES_9[(orden - 1) % 9];
  const selHdad = document.getElementById('selector-hermandad');

  let hdadActual = null;

  const coloresDiasNaz     = datos.dias.map((d) => colDia(d.orden));
  const coloresDiasCortejo = datos.dias.map((d) => colDia(d.orden) + '80');

  new Chart(document.getElementById('grafica-dias'), {
    type: 'bar',
    data: {
      labels: datos.dias.map((d) => d.nombre),
      datasets: [
        {
          label: 'Nazarenos',
          data: datos.dias.map((d) => d.noNaz),
          backgroundColor: coloresDiasNaz,
          borderWidth: 0,
        },
        {
          label: 'Cortejo total',
          data: datos.dias.map((d) => d.noTotal),
          backgroundColor: coloresDiasCortejo,
          borderWidth: 0,
        },
      ],
    },
    options: {
      animation: noAnim ? false : undefined,
      responsive: true,
      maintainAspectRatio: false,
      plugins: {
        legend: { position: 'bottom' },
        tooltip: {
          callbacks: {
            title: (items) => items[0]?.label ?? '',
            label: (c) => `${c.dataset.label}: ${nf.format(c.parsed.y)}`,
          },
        },
      },
      scales: { y: { beginAtZero: true, ticks: { callback: (v) => nf.format(v) } } },
    },
  });

  function emitir() {
    document.dispatchEvent(new CustomEvent('hdad-sel', { detail: { slug: hdadActual } }));
  }

  selHdad.addEventListener('change', () => {
    hdadActual = selHdad.value || null;
    emitir();
  });
</script>
