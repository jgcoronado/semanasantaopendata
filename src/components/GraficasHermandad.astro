---
// Gráficas de una hermandad a lo largo de los años:
//  - una tarta por año con su % sobre el total del día (conmutable: nazarenos / cortejo),
//  - un histograma (barras agrupadas) con nazarenos y cortejo por año.
// `datos` llega ordenado ascendente por año.
const { nombre, datos } = Astro.props;

const r1 = (n) => Math.round(n * 10) / 10;
const datosCliente = {
  nombre,
  anios: datos.map((x) => x.anio),
  noNaz: datos.map((x) => x.noNaz),
  noTotal: datos.map((x) => x.noTotal),
  pies: datos.map((x) => ({
    anio: x.anio,
    naz: { hdad: x.noNaz, resto: Math.max(x.diaNoNaz - x.noNaz, 0), pct: r1(x.pctNaz) },
    total: { hdad: x.noTotal, resto: Math.max(x.diaNoTotal - x.noTotal, 0), pct: r1(x.pctTotal) },
  })),
};
const hayVariosAnios = datos.length >= 2;
---

<div class="controles" role="group" aria-label="Métrica de las tartas">
  <span class="campo" style="gap:.4rem">
    Métrica de las tartas
    <span class="segmento">
      <label><input type="radio" name="metrica-hdad" value="naz" checked /> Nazarenos</label>
      <label><input type="radio" name="metrica-hdad" value="total" /> Cortejo total</label>
    </span>
  </span>
</div>

<div class="pies-grid">
  {datos.map((x) => (
    <figure class="grafica">
      <figcaption><strong>{x.anio}</strong> · <span class="pie-metrica">% de nazarenos</span> sobre el día</figcaption>
      <div class="grafica__lienzo grafica__lienzo--pie"><canvas class="pie-anio" data-anio={x.anio} aria-label={`Porcentaje sobre el día en ${x.anio}`}></canvas></div>
    </figure>
  ))}
</div>

{hayVariosAnios && (
  <figure class="grafica grafica--ancha" style="margin-top:1.2rem">
    <figcaption>Nazarenos y cortejo por año</figcaption>
    <div class="grafica__lienzo"><canvas id="hist-hdad" aria-label="Nazarenos y cortejo por año"></canvas></div>
  </figure>
)}

<script type="application/json" id="datos-graficas-hdad" set:html={JSON.stringify(datosCliente)}></script>
<script>
  import { Chart, PieController, ArcElement, BarController, BarElement, CategoryScale, LinearScale, Tooltip, Legend } from 'chart.js';
  Chart.register(PieController, ArcElement, BarController, BarElement, CategoryScale, LinearScale, Tooltip, Legend);

  const datos = JSON.parse(document.getElementById('datos-graficas-hdad').textContent);
  const MORADO = '#5b2a86';
  const ORO = '#c8a24a';
  const MORADO_CLARO = '#ddd2ec';
  const nf = new Intl.NumberFormat('es-ES', { useGrouping: 'always' });

  // Plugin inline: dibuja el % de cada porción dentro de la tarta.
  const pctEnTarta = {
    id: 'pctEnTarta',
    afterDatasetsDraw(chart) {
      const { ctx } = chart;
      const ds = chart.data.datasets[0];
      const total = ds.data.reduce((a, b) => a + b, 0);
      if (!total) return;
      chart.getDatasetMeta(0).data.forEach((arco, i) => {
        const pct = (ds.data[i] / total) * 100;
        if (pct < 6) return; // no etiquetar porciones diminutas
        const { x, y } = arco.tooltipPosition();
        ctx.save();
        ctx.font = 'bold 14px system-ui, sans-serif';
        ctx.textAlign = 'center';
        ctx.textBaseline = 'middle';
        ctx.fillStyle = '#1c1a22';
        ctx.fillText(`${pct.toFixed(1)} %`, x, y);
        ctx.restore();
      });
    },
  };

  let metrica = 'naz';
  const datosPie = (anio) => datos.pies.find((x) => x.anio === anio)[metrica];

  // Tartas: una por año (conmutables entre nazarenos y cortejo).
  const tartas = new Map();
  document.querySelectorAll('canvas.pie-anio').forEach((cv) => {
    const anio = Number(cv.dataset.anio);
    const p = datosPie(anio);
    const ch = new Chart(cv, {
      type: 'pie',
      plugins: [pctEnTarta],
      data: {
        labels: [datos.nombre, 'Resto del día'],
        datasets: [{ data: [p.hdad, p.resto], backgroundColor: [ORO, MORADO_CLARO], borderColor: '#fff', borderWidth: 2 }],
      },
      options: {
        responsive: true, maintainAspectRatio: false,
        plugins: {
          legend: { position: 'bottom' },
          tooltip: {
            callbacks: {
              label: (c) => {
                const total = c.dataset.data[0] + c.dataset.data[1];
                const pct = total ? ((c.parsed / total) * 100).toFixed(1) : '0';
                return `${c.label}: ${nf.format(c.parsed)} (${pct} %)`;
              },
            },
          },
        },
      },
    });
    tartas.set(anio, ch);
  });

  function aplicarMetrica(m) {
    metrica = m;
    tartas.forEach((ch, anio) => {
      const p = datosPie(anio);
      ch.data.datasets[0].data = [p.hdad, p.resto];
      ch.update();
    });
    const palabra = m === 'naz' ? '% de nazarenos' : '% del cortejo';
    document.querySelectorAll('.pie-metrica').forEach((el) => { el.textContent = palabra; });
  }

  document.querySelectorAll('input[name="metrica-hdad"]').forEach((r) => {
    r.addEventListener('change', () => { if (r.checked) aplicarMetrica(r.value); });
  });

  // Histograma: agrupado por magnitud (Nazarenos / Cortejo), una barra por año.
  const PALETA_ANIOS = ['#5b2a86', '#c8a24a', '#3d8a6b', '#b5462f', '#2f6fb5'];
  const cvHist = document.getElementById('hist-hdad');
  if (cvHist) {
    new Chart(cvHist, {
      type: 'bar',
      data: {
        labels: ['Nazarenos', 'Cortejo total'],
        datasets: datos.anios.map((an, i) => ({
          label: String(an),
          data: [datos.noNaz[i], datos.noTotal[i]],
          backgroundColor: PALETA_ANIOS[(datos.anios.length - 1 - i) % PALETA_ANIOS.length],
        })),
      },
      options: {
        responsive: true, maintainAspectRatio: false,
        plugins: {
          legend: { position: 'bottom' },
          tooltip: { callbacks: { label: (c) => `${c.dataset.label}: ${nf.format(c.parsed.y)}` } },
        },
        scales: { y: { beginAtZero: true, ticks: { callback: (v) => nf.format(v) } } },
      },
    });
  }
</script>
