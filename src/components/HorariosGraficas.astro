---
const { registros, dias } = Astro.props;

const datosCliente = {
  dias: dias.map((d) => ({ slug: d.slug, nombre: d.nombre })),
  registros: registros.map((r) => ({
    slug: r.slug,
    nombre: r.nombre,
    diaSlug: r.diaSlug,
    diaOrden: r.diaOrden,
    salidaMin: r.salidaMin,
    entradaMin: r.entradaMin,
    campanaMin: r.min.campana,
    ultimoPasoFueraMin: r.min.ultimoPasoFuera,
    duracionMin: r.duracionMin,
    noTotal: r.noTotal,
    partPorHora: r.partPorHora,
  })),
};
// Altura para las barras globales (una fila por hermandad).
const altoGlobal = Math.max(420, registros.length * 20);
---

<section class="panel contenedor" id="cronograma">
  <div class="panel__cab"><h2>Por día</h2></div>
  <div class="controles">
    <label class="campo">
      Día
      <select id="sel-dia-crono">
        {dias.map((d) => <option value={d.slug}>{d.nombre}</option>)}
      </select>
    </label>
  </div>

  <div class="graficas-grid">
    <figure class="grafica grafica--ancha">
      <figcaption>Cronograma: tiempo de cada cofradía en la calle (salida → entrada)</figcaption>
      <div class="grafica__lienzo" style="height:460px"><canvas id="gantt" aria-label="Cronograma de cofradías por día"></canvas></div>
    </figure>
    <figure class="grafica grafica--ancha">
      <figcaption>Cofradías a la vez en la Carrera Oficial (pasa el ratón para ver cuáles)</figcaption>
      <div class="grafica__lienzo"><canvas id="ocupacion" aria-label="Ocupación de la Carrera Oficial"></canvas></div>
    </figure>
    <figure class="grafica grafica--ancha">
      <figcaption>Distribución de salidas y entradas por hora</figcaption>
      <div class="grafica__lienzo"><canvas id="distribucion" aria-label="Distribución de salidas y entradas"></canvas></div>
    </figure>
  </div>
</section>

<section class="panel contenedor" id="global-horarios">
  <div class="panel__cab"><h2>Comparativa global</h2></div>
  <p class="descargas-intro">Cada punto/barra es una hermandad (color por día). La dispersión cruza tamaño y duración.</p>

  <figure class="grafica grafica--ancha">
    <figcaption>Duración (horas) frente a participantes del cortejo</figcaption>
    <div class="grafica__lienzo" style="height:420px"><canvas id="dispersion-dur" aria-label="Duración frente a participantes"></canvas></div>
  </figure>

  <div class="graficas-grid" style="margin-top:1.2rem">
    <figure class="grafica grafica--ancha">
      <figcaption>Duración total por hermandad</figcaption>
      <div class="grafica__lienzo" style={`height:${altoGlobal}px`}><canvas id="dur-hdad" aria-label="Duración por hermandad"></canvas></div>
    </figure>
    <figure class="grafica grafica--ancha">
      <figcaption>Participantes por hora (cortejo ÷ duración)</figcaption>
      <div class="grafica__lienzo" style={`height:${altoGlobal}px`}><canvas id="pph-hdad" aria-label="Participantes por hora por hermandad"></canvas></div>
    </figure>
  </div>
</section>

<script type="application/json" id="datos-horarios" set:html={JSON.stringify(datosCliente)}></script>
<script>
  import { Chart, BarController, BarElement, LineController, LineElement, PointElement, ScatterController, CategoryScale, LinearScale, Tooltip, Legend, Filler } from 'chart.js';
  Chart.register(BarController, BarElement, LineController, LineElement, PointElement, ScatterController, CategoryScale, LinearScale, Tooltip, Legend, Filler);

  const datos = JSON.parse(document.getElementById('datos-horarios').textContent);
  const MORADO = '#5b2a86';
  const ORO = '#c8a24a';
  // Paleta por día (índice = diaOrden - 1).
  const DIA_COL = ['#5b2a86', '#c8a24a', '#2f6fb5', '#3d8a6b', '#b5462f', '#8a5cc0', '#caa53a', '#3a8f8f', '#b07d2a'];
  const colorDia = (orden) => DIA_COL[(orden - 1) % DIA_COL.length];
  const reloj = (m) => `${String(Math.floor((((m % 1440) + 1440) % 1440) / 60)).padStart(2, '0')}:${String(((m % 60) + 60) % 60).padStart(2, '0')}`;
  const dur = (m) => { const h = Math.floor(m / 60); return h > 0 ? `${h} h ${String(m % 60).padStart(2, '0')} min` : `${m} min`; };

  // ---------- Por día: Gantt ----------
  const chartGantt = new Chart(document.getElementById('gantt'), {
    type: 'bar',
    data: { labels: [], datasets: [{ label: 'En la calle', data: [], backgroundColor: 'rgba(91,42,134,0.78)', borderColor: MORADO, borderWidth: 1, borderSkipped: false }] },
    options: {
      indexAxis: 'y', responsive: true, maintainAspectRatio: false,
      plugins: { legend: { display: false }, tooltip: { callbacks: { label: (c) => `${reloj(c.raw[0])} – ${reloj(c.raw[1])} (${dur(c.raw[1] - c.raw[0])})` } } },
      scales: { x: { min: 0, max: 1440, ticks: { stepSize: 60, callback: (v) => reloj(v) }, title: { display: true, text: 'Hora' } }, y: { ticks: { autoSkip: false } } },
    },
  });

  // ---------- Por día: ocupación de la Carrera Oficial ----------
  let ocupNombres = [];
  const chartOcup = new Chart(document.getElementById('ocupacion'), {
    type: 'line',
    data: { labels: [], datasets: [{ label: 'Cofradías en la Carrera Oficial', data: [], borderColor: ORO, backgroundColor: 'rgba(200,162,74,0.25)', fill: true, tension: 0.25, pointRadius: 0 }] },
    options: {
      responsive: true, maintainAspectRatio: false,
      plugins: {
        legend: { display: false },
        tooltip: {
          callbacks: {
            label: (c) => `${c.parsed.y} cofradía${c.parsed.y === 1 ? '' : 's'}`,
            afterBody: (items) => ocupNombres[items[0].dataIndex] || [],
          },
        },
      },
      scales: { y: { beginAtZero: true, ticks: { precision: 0 } }, x: { ticks: { maxTicksLimit: 12 } } },
    },
  });

  // ---------- Por día: distribución de salidas y entradas ----------
  const chartDist = new Chart(document.getElementById('distribucion'), {
    type: 'bar',
    data: { labels: [], datasets: [
      { label: 'Salidas', data: [], backgroundColor: MORADO },
      { label: 'Entradas', data: [], backgroundColor: ORO },
    ] },
    options: { responsive: true, maintainAspectRatio: false, plugins: { legend: { position: 'bottom' } }, scales: { y: { beginAtZero: true, ticks: { precision: 0 } } } },
  });

  const selDia = document.getElementById('sel-dia-crono');
  function pintarDia() {
    const regs = datos.registros.filter((r) => r.diaSlug === selDia.value).sort((a, b) => a.salidaMin - b.salidaMin);

    // Gantt con eje X ajustado al rango real del día (margen de 20 min).
    chartGantt.data.labels = regs.map((r) => r.nombre);
    chartGantt.data.datasets[0].data = regs.map((r) => [r.salidaMin, r.entradaMin]);
    const minX = Math.min(...regs.map((r) => r.salidaMin)) - 20;
    const maxX = Math.max(...regs.map((r) => r.entradaMin)) + 20;
    chartGantt.options.scales.x.min = minX;
    chartGantt.options.scales.x.max = maxX;
    chartGantt.update();

    // Ocupación (paso de 5 min) + nombres para el tooltip.
    const paso = 5;
    const ini = Math.floor(Math.min(...regs.map((r) => r.campanaMin)) / paso) * paso;
    const fin = Math.max(...regs.map((r) => r.ultimoPasoFueraMin));
    const labels = [], conteo = [], nombres = [];
    for (let t = ini; t <= fin; t += paso) {
      const dentro = regs.filter((r) => r.campanaMin <= t && t <= r.ultimoPasoFueraMin);
      labels.push(reloj(t));
      conteo.push(dentro.length);
      nombres.push(dentro.map((r) => '• ' + r.nombre));
    }
    chartOcup.data.labels = labels;
    chartOcup.data.datasets[0].data = conteo;
    ocupNombres = nombres;
    chartOcup.update();

    // Distribución por hora (de la primera salida a la última entrada).
    const hIni = Math.floor(Math.min(...regs.map((r) => r.salidaMin)) / 60);
    const hFin = Math.ceil(Math.max(...regs.map((r) => r.entradaMin)) / 60);
    const hLabels = [], salidas = [], entradas = [];
    for (let h = hIni; h < hFin; h++) {
      hLabels.push(reloj(h * 60));
      salidas.push(regs.filter((r) => Math.floor(r.salidaMin / 60) === h).length);
      entradas.push(regs.filter((r) => Math.floor(r.entradaMin / 60) === h).length);
    }
    chartDist.data.labels = hLabels;
    chartDist.data.datasets[0].data = salidas;
    chartDist.data.datasets[1].data = entradas;
    chartDist.update();
  }
  selDia.addEventListener('change', pintarDia);
  pintarDia();

  // ---------- Global: dispersión duración vs tamaño ----------
  new Chart(document.getElementById('dispersion-dur'), {
    type: 'scatter',
    data: { datasets: [{ label: 'Hermandades', data: datos.registros.map((r) => ({ x: r.noTotal, y: Math.round((r.duracionMin / 60) * 10) / 10, nombre: r.nombre })), backgroundColor: datos.registros.map((r) => colorDia(r.diaOrden)), pointRadius: 5, pointHoverRadius: 7 }] },
    options: {
      responsive: true, maintainAspectRatio: false,
      plugins: { legend: { display: false }, tooltip: { callbacks: { label: (c) => `${c.raw.nombre}: ${c.raw.x.toLocaleString('es-ES')} participantes · ${c.raw.y} h` } } },
      scales: { x: { title: { display: true, text: 'Participantes (cortejo)' }, beginAtZero: true }, y: { title: { display: true, text: 'Duración (horas)' }, beginAtZero: true } },
    },
  });

  // ---------- Global: barras por hermandad (color por día) ----------
  function barrasGlobales(canvasId, valor, fmtTip) {
    const orden = [...datos.registros].sort((a, b) => valor(b) - valor(a));
    new Chart(document.getElementById(canvasId), {
      type: 'bar',
      data: { labels: orden.map((r) => r.nombre), datasets: [{ data: orden.map(valor), backgroundColor: orden.map((r) => colorDia(r.diaOrden)) }] },
      options: {
        indexAxis: 'y', responsive: true, maintainAspectRatio: false,
        plugins: { legend: { display: false }, tooltip: { callbacks: { label: (c) => fmtTip(c.raw) } } },
        scales: { x: { beginAtZero: true }, y: { ticks: { autoSkip: false, font: { size: 10 } } } },
      },
    });
  }
  barrasGlobales('dur-hdad', (r) => r.duracionMin, (v) => dur(v));
  barrasGlobales('pph-hdad', (r) => r.partPorHora ?? 0, (v) => `${v.toLocaleString('es-ES')} participantes/hora`);
</script>
