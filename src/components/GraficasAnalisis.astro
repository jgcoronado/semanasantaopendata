---
const { registros, sinDatos, porDia, dias, comparativaRows, comparativaAnio, anioActual } = Astro.props;

const diasOrd = [...dias].sort((a, b) => a.orden - b.orden);

// Paleta oficial (un color único por día litúrgico, orden 1-9)
const COLORES_9 = ['#6929c4','#1192e8','#005d5d','#9f1853','#fa4d56','#198038','#b28600','#012749','#8a3800'];
// Solo formas con relleno: círculo, triángulo, cuadrado (ciclo de 3)
const SIMBOLOS_3 = ['circle','triangle','rect'];

const estiloDia = (orden) => ({
  color:   COLORES_9[(orden - 1) % 9],
  simbolo: SIMBOLOS_3[(orden - 1) % 3],
});

// Colores para composición del cortejo (stacked bars, tipos de participante)
const COL_COMP = {
  nazarenos:   '#6929c4',
  penitentes:  '#1192e8',
  acolitos:    '#198038',
  monaguillos: '#b28600',
  acompCortejo:'#9f1853',
};

// Helper: fondo de fila con el color del día al 10% de opacidad
function diaBg(orden) {
  const hex = COLORES_9[(orden - 1) % 9] ?? '#888888';
  const r = parseInt(hex.slice(1, 3), 16);
  const g = parseInt(hex.slice(3, 5), 16);
  const b = parseInt(hex.slice(5, 7), 16);
  return `rgba(${r},${g},${b},0.10)`;
}

const altoRanking = Math.max(420, registros.length * 24);

const datosCliente = {
  dias: diasOrd.map((d) => ({ slug: d.slug, nombre: d.nombre, orden: d.orden })),
  registros: registros.map((r) => ({
    nombre:            r.nombre,
    diaSlug:           r.diaSlug,
    diaOrden:          r.diaOrden,
    noTotal:           r.noTotal,
    noNaz:             r.noNaz,
    nazarenos:         r.nazarenos,
    penitentes:        r.penitentes,
    acolitos:          r.acolitos,
    monaguillos:       r.monaguillos,
    acompCortejo:      r.acompCortejo,
    duracionMin:       r.duracionMin,
    totalPorMinuto:    r.totalPorMinuto,
    nazarenosPorMinuto:r.nazarenosPorMinuto,
  })),
  porDia,
  colComp: COL_COMP,
};
---

<!-- ======================== DISPERSIÓN: DURACIÓN VS TAMAÑO ======================== -->
<section class="panel contenedor" id="dispersion">
  <div class="panel__cab"><h2>Duración frente a tamaño del cortejo</h2></div>
  <p class="descargas-intro">
    Cada punto es una cofradía. El eje horizontal muestra el total de participantes y el vertical
    la duración de la estación de penitencia. El color y la forma indican el día procesional.
  </p>

  <ul class="leyenda-dias" aria-label="Días procesionales">
    {diasOrd.map((d) => {
      const e = estiloDia(d.orden);
      const forma = e.simbolo === 'circle' ? 'circle'
                  : e.simbolo === 'triangle' ? 'triangle'
                  : 'rect';
      return (
        <li class="leyenda-dias__item">
          <svg width="18" height="18" viewBox="0 0 18 18" aria-hidden="true" style="flex-shrink:0">
            {forma === 'circle'   && <circle cx="9" cy="9" r="8" fill={e.color} />}
            {forma === 'triangle' && <polygon points="9,1 17,17 1,17" fill={e.color} />}
            {forma === 'rect'     && <rect x="1" y="1" width="16" height="16" rx="2" fill={e.color} />}
          </svg>
          <span>{d.nombre}</span>
        </li>
      );
    })}
  </ul>

  <figure class="grafica grafica--ancha">
    <figcaption>Duración (horas) frente a total de participantes del cortejo</figcaption>
    <div class="grafica__lienzo" style="height:420px">
      <canvas id="an-dispersion" aria-label="Dispersión duración vs tamaño"></canvas>
    </div>
  </figure>
</section>

<!-- ======================== COMPOSICIÓN DEL CORTEJO ======================== -->
<section class="panel contenedor" id="composicion">
  <div class="panel__cab"><h2>Composición del cortejo</h2></div>
  <p class="descargas-intro">
    Cofradías ordenadas de mayor a menor total de participantes. Cada segmento muestra el
    desglose por tipo: nazarenos, penitentes, acólitos, monaguillos y acompañamiento del cortejo.
  </p>

  <ul class="leyenda-dias" aria-label="Tipos de participantes">
    {Object.entries(COL_COMP).map(([clave, color]) => {
      const etiquetas = { nazarenos:'Nazarenos', penitentes:'Penitentes', acolitos:'Acólitos', monaguillos:'Monaguillos', acompCortejo:'Acompañamiento' };
      return (
        <li class="leyenda-dias__item">
          <svg width="18" height="18" viewBox="0 0 18 18" aria-hidden="true" style="flex-shrink:0">
            <rect x="1" y="1" width="16" height="16" rx="2" fill={color} />
          </svg>
          <span>{etiquetas[clave]}</span>
        </li>
      );
    })}
  </ul>

  <figure class="grafica grafica--ancha">
    <figcaption>Total de participantes por hermandad (desglose por tipo)</figcaption>
    <div class="grafica__lienzo" style={`height:${altoRanking}px`}>
      <canvas id="an-composicion" aria-label="Composición del cortejo por hermandad"></canvas>
    </div>
  </figure>
</section>

<!-- ======================== NAZARENOS EN CALLE ======================== -->
<section class="panel contenedor" id="en-calle">
  <div class="panel__cab"><h2>Nazarenos en la calle por hora</h2></div>
  <p class="descargas-intro">
    Suma de nazarenos simultáneamente en la calle a lo largo del día, para todas las cofradías
    que procesionan ese día. Muestra los picos de afluencia en cada jornada.
  </p>
  <div class="controles">
    <label class="campo">
      Día
      <select id="sel-dia-calle">
        {diasOrd.map((d) => <option value={d.slug}>{d.nombre}</option>)}
      </select>
    </label>
  </div>
  <figure class="grafica grafica--ancha">
    <figcaption>Nazarenos en la calle a cada hora del día</figcaption>
    <div class="grafica__lienzo" style="height:320px">
      <canvas id="an-encalle" aria-label="Nazarenos en la calle por hora"></canvas>
    </div>
  </figure>
</section>

<!-- ======================== DENSIDAD DEL DESFILE ======================== -->
<section class="panel contenedor" id="densidad">
  <div class="panel__cab"><h2>Densidad del desfile</h2></div>
  <p class="descargas-intro">
    Miembros del cortejo por minuto de tiempo de paso. Las cofradías con ratio alto
    concentran su cortejo; las de ratio bajo lo espacian en el tiempo.
  </p>
  <figure class="grafica grafica--ancha">
    <figcaption>Miembros del cortejo por minuto de tiempo de paso</figcaption>
    <div class="grafica__lienzo" style={`height:${altoRanking}px`}>
      <canvas id="an-densidad" aria-label="Densidad del desfile por hermandad"></canvas>
    </div>
  </figure>
</section>

<!-- ======================== BOX PLOT: DISTRIBUCIÓN POR JORNADA ======================== -->
<section class="panel contenedor" id="boxplot">
  <div class="panel__cab"><h2>Distribución por jornada: nazarenos y duración</h2></div>
  <p class="descargas-intro">
    Diagrama de cajas y bigotes del total de nazarenos por cortejo y de la duración de cada
    procesión, agrupados por día procesional. La caja muestra el rango intercuartílico (Q1–Q3),
    la línea central la mediana y los bigotes el rango completo salvo valores atípicos.
  </p>
  <div class="boxplot-grid">
    <figure class="grafica">
      <figcaption>Nazarenos por cortejo</figcaption>
      <div class="grafica__lienzo" style="height:360px">
        <canvas id="an-box-naz" aria-label="Box plot: nazarenos por cortejo"></canvas>
      </div>
    </figure>
    <figure class="grafica">
      <figcaption>Duración de la estación de penitencia</figcaption>
      <div class="grafica__lienzo" style="height:360px">
        <canvas id="an-box-dur" aria-label="Box plot: duración de la estación de penitencia"></canvas>
      </div>
    </figure>
  </div>
</section>

<!-- ======================== COMPARATIVA ENTRE AÑOS ======================== -->
{comparativaRows && comparativaRows.length > 0 && (
  <section class="panel contenedor" id="comparativa-analisis">
    <div class="panel__cab">
      <h2>Comparativa {anioActual} vs {comparativaAnio}</h2>
    </div>
    <p class="descargas-intro">
      Variación en número de participantes y duración de la estación de penitencia entre ambos años.
      Las hermandades marcadas con <strong>sin datos</strong> no procesionaron ese año (posible lluvia o suspensión).
    </p>
    <div style="overflow-x:auto">
      <table class="tabla-comparativa">
        <thead>
          <tr>
            <th>Hermandad</th>
            <th>Día</th>
            <th>Participantes {anioActual}</th>
            <th>Participantes {comparativaAnio}</th>
            <th>Variación</th>
            <th>Duración {anioActual}</th>
            <th>Duración {comparativaAnio}</th>
          </tr>
        </thead>
        <tbody>
          {comparativaRows.map((r) => {
            const delta = r.otroNoTotal != null && r.noTotal != null
              ? Math.round((r.noTotal - r.otroNoTotal) / r.otroNoTotal * 1000) / 10
              : null;
            const deltaDur = r.otroDuracionMin != null && r.duracionMin != null
              ? r.duracionMin - r.otroDuracionMin
              : null;
            return (
              <tr style={`background-color:${diaBg(r.diaOrden)}`}>
                <td>{r.nombre}</td>
                <td>{r.diaNombre}</td>
                <td class="num">{r.noTotal != null ? r.noTotal.toLocaleString('es-ES') : '—'}</td>
                <td class="num">
                  {r.otroSinDatos
                    ? <span class="sin-datos" title={`Sin datos en ${comparativaAnio}`}>sin datos</span>
                    : r.otroNoTotal != null ? r.otroNoTotal.toLocaleString('es-ES') : '—'}
                </td>
                <td class="num">
                  {delta != null
                    ? <span class={delta > 0 ? 'sube' : delta < 0 ? 'baja' : ''}>{delta > 0 ? '+' : ''}{delta.toLocaleString('es-ES', {minimumFractionDigits:1,maximumFractionDigits:1})} %</span>
                    : '—'}
                </td>
                <td class="num">
                  {r.duracionMin != null
                    ? `${Math.floor(r.duracionMin/60)} h ${String(r.duracionMin%60).padStart(2,'0')} min`
                    : '—'}
                </td>
                <td class="num">
                  {r.otroSinDatos
                    ? <span class="sin-datos">sin datos</span>
                    : r.otroDuracionMin != null
                      ? `${Math.floor(r.otroDuracionMin/60)} h ${String(r.otroDuracionMin%60).padStart(2,'0')} min`
                      : '—'}
                </td>
              </tr>
            );
          })}
        </tbody>
      </table>
    </div>
  </section>
)}

<!-- ======================== SIN DATOS ======================== -->
{sinDatos && sinDatos.length > 0 && (
  <section class="panel contenedor" id="sin-datos">
    <div class="panel__cab"><h2>Hermandades sin datos</h2></div>
    <p class="descargas-intro">
      Las siguientes hermandades figuran en el calendario oficial pero no tienen datos de conteo
      ese año, posiblemente por lluvia o suspensión.
    </p>
    <ul style="columns:2;gap:2rem;list-style:none;padding:0;margin:0">
      {sinDatos.map((r) => (
        <li style="margin-bottom:.4rem">
          <strong>{r.nombre}</strong> <span style="color:var(--gris-medio,#777)">· {r.diaNombre}</span>
        </li>
      ))}
    </ul>
  </section>
)}

<!-- ======================== PLACEHOLDER VELOCIDAD ======================== -->
<section class="panel contenedor" id="velocidad">
  <div class="panel__cab"><h2>Velocidad real del desfile</h2></div>
  <div class="kpi" style="max-width:480px;opacity:.55;cursor:default">
    <div class="kpi__num" style="font-size:1.3rem">Próximamente</div>
    <div class="kpi__lbl">
      Esta sección calculará la velocidad en km/h cuando se añadan las distancias de recorrido
      de cada hermandad.
    </div>
  </div>
</section>

<script type="application/json" id="datos-analisis" set:html={JSON.stringify(datosCliente)}></script>
<script>
  import {
    Chart, BarController, BarElement, ScatterController,
    LineController, LineElement, PointElement,
    CategoryScale, LinearScale, Tooltip, Legend, Filler,
  } from 'chart.js';
  import { BoxPlotController, BoxAndWiskers } from '@sgratzl/chartjs-chart-boxplot';
  Chart.register(
    BarController, BarElement, ScatterController,
    LineController, LineElement, PointElement,
    CategoryScale, LinearScale, Tooltip, Legend, Filler,
    BoxPlotController, BoxAndWiskers,
  );

  const datos = JSON.parse(document.getElementById('datos-analisis').textContent);
  const dur = (m) => { const h = Math.floor(m / 60); return h > 0 ? `${h} h ${String(m % 60).padStart(2,'0')} min` : `${m} min`; };

  // Paleta oficial (orden 1-9)
  const COLORES_9 = ['#6929c4','#1192e8','#005d5d','#9f1853','#fa4d56','#198038','#b28600','#012749','#8a3800'];
  const SIMBOLOS_3 = ['circle','triangle','rect'];

  const estiloDia = (orden) => ({
    color:   COLORES_9[(orden - 1) % 9],
    simbolo: SIMBOLOS_3[(orden - 1) % 3],
  });

  // ── §1 Dispersión: duración vs tamaño ──
  const scatterDs = datos.dias
    .filter((d) => datos.registros.some((r) => r.diaSlug === d.slug))
    .map((d) => {
      const e = estiloDia(d.orden);
      return {
        label: d.nombre,
        data: datos.registros
          .filter((r) => r.diaSlug === d.slug && r.noTotal != null && r.duracionMin != null)
          .map((r) => ({ x: r.noTotal, y: +(r.duracionMin / 60).toFixed(2), nombre: r.nombre })),
        backgroundColor: e.color + 'bb',
        borderColor: e.color,
        pointStyle: e.simbolo,
        pointRadius: 7,
        pointHoverRadius: 9,
      };
    });

  new Chart(document.getElementById('an-dispersion'), {
    type: 'scatter',
    data: { datasets: scatterDs },
    options: {
      responsive: true, maintainAspectRatio: false,
      plugins: {
        legend: { position: 'bottom', labels: { usePointStyle: true, pointStyleWidth: 14, padding: 14 } },
        tooltip: {
          usePointStyle: true,
          callbacks: {
            title: (items) => items[0]?.raw?.nombre ?? '',
            label: (c) => `${c.raw.x.toLocaleString('es-ES')} part. · ${dur(Math.round(c.raw.y * 60))}`,
          },
        },
      },
      scales: {
        x: { title: { display: true, text: 'Participantes (cortejo total)' }, beginAtZero: true },
        y: { title: { display: true, text: 'Duración (horas)' }, beginAtZero: true },
      },
    },
  });

  // ── §2 Composición del cortejo (stacked horizontal bars) ──
  const ordenComp = [...datos.registros]
    .filter((r) => r.noTotal != null)
    .sort((a, b) => b.noTotal - a.noTotal);

  const labelsComp = ordenComp.map((r) => r.nombre);
  const capas = [
    { key: 'nazarenos',    label: 'Nazarenos',     color: datos.colComp.nazarenos },
    { key: 'penitentes',   label: 'Penitentes',    color: datos.colComp.penitentes },
    { key: 'acolitos',     label: 'Acólitos',      color: datos.colComp.acolitos },
    { key: 'monaguillos',  label: 'Monaguillos',   color: datos.colComp.monaguillos },
    { key: 'acompCortejo', label: 'Acompañamiento',color: datos.colComp.acompCortejo },
  ];

  new Chart(document.getElementById('an-composicion'), {
    type: 'bar',
    data: {
      labels: labelsComp,
      datasets: capas.map((c) => ({
        label: c.label,
        data: ordenComp.map((r) => r[c.key] ?? 0),
        backgroundColor: c.color + 'dd',
        borderColor: c.color,
        borderWidth: 0,
        stack: 'cortejo',
      })),
    },
    options: {
      indexAxis: 'y', responsive: true, maintainAspectRatio: false,
      interaction: { mode: 'index', intersect: false, axis: 'y' },
      plugins: {
        legend: { position: 'bottom', labels: { padding: 14 } },
        tooltip: {
          callbacks: {
            title: (items) => items[0]?.label ?? '',
            footer: (items) => `Total: ${items.reduce((s, i) => s + i.parsed.x, 0).toLocaleString('es-ES')}`,
          },
        },
      },
      scales: {
        x: { stacked: true, title: { display: true, text: 'Participantes' } },
        y: { stacked: true, ticks: { autoSkip: false, font: { size: 10 } } },
      },
    },
  });

  // ── §3 Nazarenos en calle por hora ──
  const selDia = document.getElementById('sel-dia-calle');
  const diaOrdenActual = () => datos.dias.find((d) => d.slug === selDia.value)?.orden ?? 1;
  const colorCalle = () => COLORES_9[(diaOrdenActual() - 1) % 9];

  const chartCalle = new Chart(document.getElementById('an-encalle'), {
    type: 'line',
    data: { labels: [], datasets: [{ data: [], borderColor: COLORES_9[0], backgroundColor: COLORES_9[0] + '2e', fill: true, tension: 0.3, pointRadius: 0, pointHoverRadius: 4 }] },
    options: {
      responsive: true, maintainAspectRatio: false,
      interaction: { mode: 'index', intersect: false },
      plugins: { legend: { display: false }, tooltip: { callbacks: { label: (c) => `${c.parsed.y.toLocaleString('es-ES')} nazarenos en la calle` } } },
      scales: {
        y: { beginAtZero: true, title: { display: true, text: 'Nazarenos' } },
        x: { ticks: { maxTicksLimit: 12 } },
      },
    },
  });

  const parseMin = (hhmm) => { const [h, m] = hhmm.split(':').map(Number); return h * 60 + m; };
  const fmtHHMM = (mins) => { const t = ((mins % 1440) + 1440) % 1440; return `${String(Math.floor(t / 60)).padStart(2,'0')}:${String(t % 60).padStart(2,'0')}`; };

  function pintarCalle() {
    const slug = selDia.value;
    const serie = datos.porDia[slug];
    if (!serie || !serie.serieTiempo.length) return;
    const puntos = serie.serieTiempo;
    const conPadding = [
      { hhmm: fmtHHMM(parseMin(puntos[0].hhmm) - 60), nazarenos: 0 },
      ...puntos,
      { hhmm: fmtHHMM(parseMin(puntos[puntos.length - 1].hhmm) + 60), nazarenos: 0 },
    ];
    const col = colorCalle();
    chartCalle.data.labels = conPadding.map((p) => p.hhmm);
    chartCalle.data.datasets[0].data = conPadding.map((p) => p.nazarenos);
    chartCalle.data.datasets[0].borderColor = col;
    chartCalle.data.datasets[0].backgroundColor = col + '2e';
    chartCalle.options.scales.y.max = serie.maxNazarenos + Math.ceil(serie.maxNazarenos * 0.05);
    chartCalle.update();
  }
  selDia.addEventListener('change', pintarCalle);
  pintarCalle();

  // ── §4 Densidad del desfile ──
  const ordenDens = [...datos.registros]
    .filter((r) => r.totalPorMinuto != null)
    .sort((a, b) => b.totalPorMinuto - a.totalPorMinuto);

  new Chart(document.getElementById('an-densidad'), {
    type: 'bar',
    data: {
      labels: ordenDens.map((r) => r.nombre),
      datasets: [{
        data: ordenDens.map((r) => r.totalPorMinuto),
        backgroundColor: ordenDens.map((r) => COLORES_9[(r.diaOrden - 1) % 9] + 'cc'),
        borderColor:     ordenDens.map((r) => COLORES_9[(r.diaOrden - 1) % 9]),
        borderWidth: 1,
      }],
    },
    options: {
      indexAxis: 'y', responsive: true, maintainAspectRatio: false,
      interaction: { mode: 'index', intersect: false, axis: 'y' },
      plugins: {
        legend: { display: false },
        tooltip: {
          callbacks: {
            title: (items) => items[0]?.label ?? '',
            label: (c) => `${c.raw.toLocaleString('es-ES')} miemb./min`,
          },
        },
      },
      scales: {
        x: { beginAtZero: true, title: { display: true, text: 'Miembros del cortejo por minuto' } },
        y: { ticks: { autoSkip: false, font: { size: 10 } } },
      },
    },
  });

  // ── §5 Box plots: distribución por jornada ──
  const diasConBox = datos.dias
    .filter((d) => datos.registros.some((r) => r.diaSlug === d.slug))
    .sort((a, b) => a.orden - b.orden);

  const labelsBox = ['Total', ...diasConBox.map((d) => d.nombre)];
  const coloresBox = ['#888888', ...diasConBox.map((d) => COLORES_9[(d.orden - 1) % 9])];

  const dataNzBox = [
    datos.registros.filter((r) => r.noNaz != null).map((r) => r.noNaz),
    ...diasConBox.map((d) =>
      datos.registros.filter((r) => r.diaSlug === d.slug && r.noNaz != null).map((r) => r.noNaz)
    ),
  ];

  const dataDurBox = [
    datos.registros.filter((r) => r.duracionMin != null).map((r) => r.duracionMin),
    ...diasConBox.map((d) =>
      datos.registros.filter((r) => r.diaSlug === d.slug && r.duracionMin != null).map((r) => r.duracionMin)
    ),
  ];

  const mkBoxOpts = (titleY, fmtVal) => ({
    responsive: true, maintainAspectRatio: false,
    plugins: {
      legend: { display: false },
      tooltip: {
        callbacks: {
          title: (items) => items[0]?.label ?? '',
          label: (ctx) => {
            const raw = ctx.parsed?._custom ?? ctx.parsed ?? {};
            const r = (n) => (n != null ? fmtVal(n) : '—');
            return [
              `Mediana: ${r(raw.median)}`,
              `Q1–Q3: ${r(raw.q1)} – ${r(raw.q3)}`,
              `Mín–Máx: ${r(raw.min)} – ${r(raw.max)}`,
            ];
          },
        },
      },
    },
    scales: {
      x: { ticks: { font: { size: 10 }, maxRotation: 40, minRotation: 20 } },
      y: { beginAtZero: true, title: { display: true, text: titleY } },
    },
  });

  new Chart(document.getElementById('an-box-naz'), {
    type: 'boxplot',
    data: {
      labels: labelsBox,
      datasets: [{
        data: dataNzBox,
        backgroundColor: coloresBox.map((c) => c + '55'),
        borderColor: coloresBox,
        borderWidth: 2,
        outlierRadius: 3,
      }],
    },
    options: mkBoxOpts('Nazarenos', (n) => Math.round(n).toLocaleString('es-ES')),
  });

  new Chart(document.getElementById('an-box-dur'), {
    type: 'boxplot',
    data: {
      labels: labelsBox,
      datasets: [{
        data: dataDurBox,
        backgroundColor: coloresBox.map((c) => c + '55'),
        borderColor: coloresBox,
        borderWidth: 2,
        outlierRadius: 3,
      }],
    },
    options: mkBoxOpts('Minutos', (n) => dur(Math.round(n))),
  });
</script>

