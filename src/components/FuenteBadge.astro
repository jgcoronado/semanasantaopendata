---
// Recibe un objeto fuente completo del catálogo.
// Uso: <FuenteBadge fuente={getFuente('consejo-nazarenos-2026')} />
const { fuente, mostrarFecha = false } = Astro.props;
if (!fuente) return;

const etiquetaTipo = {
  oficial: 'Oficial',
  prensa: 'Prensa',
  hermandad: 'Hermandad',
  propia: 'Elaboración propia',
};

const colorTipo = {
  oficial: '#1192e8',
  prensa: '#fa4d56',
  hermandad: '#198038',
  propia: '#b28600',
};

const color = colorTipo[fuente.tipo] ?? '#888';
const etiqueta = etiquetaTipo[fuente.tipo] ?? fuente.tipo;
---

{fuente.url ? (
  <a
    href={fuente.url}
    target="_blank"
    rel="noopener noreferrer"
    class="fuente-badge"
    style={`--fuente-color: ${color}`}
    title={fuente.descripcion ?? fuente.nombre}
  >
    <span class="fuente-badge__dot" aria-hidden="true"></span>
    <span class="fuente-badge__tipo">{etiqueta}</span>
    <span class="fuente-badge__nombre">{fuente.nombre_corto}</span>
    {mostrarFecha && fuente.fecha_consulta && (
      <span class="fuente-badge__fecha">({fuente.fecha_consulta})</span>
    )}
  </a>
) : (
  <span
    class="fuente-badge fuente-badge--sin-enlace"
    style={`--fuente-color: ${color}`}
    title={fuente.descripcion ?? fuente.nombre}
  >
    <span class="fuente-badge__dot" aria-hidden="true"></span>
    <span class="fuente-badge__tipo">{etiqueta}</span>
    <span class="fuente-badge__nombre">{fuente.nombre_corto}</span>
    {mostrarFecha && fuente.fecha_consulta && (
      <span class="fuente-badge__fecha">({fuente.fecha_consulta})</span>
    )}
  </span>
)}

<style>
  .fuente-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    font-size: 0.78rem;
    padding: 0.15rem 0.55rem 0.15rem 0.4rem;
    border-radius: 999px;
    border: 1px solid color-mix(in srgb, var(--fuente-color) 35%, transparent);
    background: color-mix(in srgb, var(--fuente-color) 8%, transparent);
    color: color-mix(in srgb, var(--fuente-color) 85%, #000);
    text-decoration: none;
    white-space: nowrap;
    line-height: 1.4;
    vertical-align: middle;
    transition: background 0.12s ease;
  }
  a.fuente-badge:hover {
    background: color-mix(in srgb, var(--fuente-color) 16%, transparent);
    text-decoration: none;
  }
  .fuente-badge__dot {
    width: 0.45rem;
    height: 0.45rem;
    border-radius: 50%;
    background: var(--fuente-color);
    flex-shrink: 0;
  }
  .fuente-badge__tipo {
    font-weight: 700;
    text-transform: uppercase;
    font-size: 0.68rem;
    letter-spacing: 0.3px;
    opacity: 0.75;
  }
  .fuente-badge__nombre {
    font-weight: 500;
  }
  .fuente-badge__fecha {
    opacity: 0.65;
  }
</style>
