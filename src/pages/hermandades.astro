---
import Base from '../layouts/Base.astro';
import FuentesResumen from '../components/FuentesResumen.astro';
import { getComparativaHermandades, anios, anioPrincipal, dias, getFuentesAnio } from '../lib/datos.js';

const norm = (s) => s.toLowerCase().normalize('NFD').replace(/[̀-ͯ]/g, '');

const fuentesHermandades = [...new Map(
  anios.flatMap((a) => getFuentesAnio(a.anio, ['nazarenos'])).map((f) => [f.id, f])
).values()];

const todasHermandades = getComparativaHermandades().map((h) => {
  const aniosConDatos = anios.filter((a) => h.porAnio[a.anio]);
  const anioEnlace = aniosConDatos[0]?.anio ?? anioPrincipal;
  return { ...h, anioEnlace, busqueda: norm(h.nombre) };
});

// Agrupar por día y ordenar dentro de cada día por id_hdad (orden de cortejo 2026)
const herDia = {};
for (const h of todasHermandades) {
  if (!herDia[h.diaSlug]) herDia[h.diaSlug] = [];
  herDia[h.diaSlug].push(h);
}
for (const slug of Object.keys(herDia)) {
  herDia[slug].sort((a, b) => a.id_hdad - b.id_hdad);
}

const totalHermandades = todasHermandades.length;

const title = 'Hermandades de la Semana Santa de Sevilla — buscador | Open Data';
const description =
  'Listado y buscador de todas las hermandades de la Semana Santa de Sevilla, con acceso a sus datos de conteo por año (nazarenos y cortejo).';
---

<Base title={title} description={description} hermandadesActiva={true}>
  <section class="hero">
    <div class="contenedor">
      <h1>Hermandades</h1>
      <p>Busca una hermandad para ver su ficha con los datos de todos los años.</p>
      <div class="buscador">
        <input
          type="search"
          id="buscador-hdad"
          placeholder="Escribe el nombre de una hermandad…"
          aria-label="Buscar hermandad"
          autocomplete="off"
        />
        <span class="buscador__contador" id="buscador-contador" aria-live="polite">{totalHermandades} hermandades</span>
      </div>
    </div>
  </section>

  <section class="panel contenedor">
    <div id="hdad-contenido">
      {dias.map((dia) => {
        const hdades = herDia[dia.slug] ?? [];
        if (!hdades.length) return null;
        return (
          <div class="hdad-dia" data-dia={dia.slug}>
            <h2 class="hdad-dia__titulo">{dia.nombre}</h2>
            <ul class="hdad-lista">
              {hdades.map((h) => (
                <li class="hdad-item" data-nombre={h.busqueda}>
                  <a href={`/${h.anioEnlace}/hermandad/${h.slug}/`}>
                    <span class="hdad-item__nombre">{h.nombre}</span>
                    <span class="hdad-item__meta">
                      <span class="hdad-item__cortejo">Cortejo de {h.porAnio[2026]?.noTotal.toLocaleString('es-ES')} personas en el año 2026</span>
                    </span>
                  </a>
                </li>
              ))}
            </ul>
          </div>
        );
      })}
    </div>
    <p class="hdad-vacio" id="hdad-vacio" hidden>No hay ninguna hermandad con ese nombre.</p>
  </section>

  <script>
    const input = document.getElementById('buscador-hdad');
    const items = Array.from(document.querySelectorAll('.hdad-item'));
    const secciones = Array.from(document.querySelectorAll('.hdad-dia'));
    const vacio = document.getElementById('hdad-vacio');
    const contador = document.getElementById('buscador-contador');
    const norm = (s) => s.toLowerCase().normalize('NFD').replace(/[̀-ͯ]/g, '');

    function filtrar() {
      const q = norm(input.value.trim());
      let n = 0;
      for (const it of items) {
        const ok = !q || it.dataset.nombre.includes(q);
        it.hidden = !ok;
        if (ok) n++;
      }
      for (const sec of secciones) {
        sec.hidden = sec.querySelectorAll('.hdad-item:not([hidden])').length === 0;
      }
      vacio.hidden = n !== 0;
      contador.textContent = `${n} hermandad${n === 1 ? '' : 'es'}`;
    }

    input.addEventListener('input', filtrar);
  </script>

  <section class="panel contenedor">
    <FuentesResumen fuentes={fuentesHermandades} />
  </section>
</Base>
