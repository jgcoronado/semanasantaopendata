---
import Base from '../layouts/Base.astro';
import FuentesResumen from '../components/FuentesResumen.astro';
import { anios, getComparativaDias, getComparativaHermandades, fmt, fmtPct, variacion, getFuentesAnio } from '../lib/datos.js';

const aniosOrden = anios.map((a) => a.anio); // descendente, p. ej. [2026, 2025, 2023]
const fuentesComparativa = [...new Map(
  anios.flatMap((a) => getFuentesAnio(a.anio, ['nazarenos'])).map((f) => [f.id, f])
).values()];
const aLatest = aniosOrden[0];
const basesPosibles = aniosOrden.slice(1); // años contra los que comparar
const baseInicial = basesPosibles[0];

const compDias = getComparativaDias();
const compHerms = getComparativaHermandades();

// Variación interanual (año más reciente vs un año base) para una métrica.
const varDe = (porAnio, metrica, base) => variacion(porAnio[aLatest]?.[metrica] ?? null, porAnio[base]?.[metrica] ?? null);
const celdaVar = (v) => (v == null ? { txt: '—', cls: '' } : { txt: (v > 0 ? '+' : '') + fmtPct(v), cls: v > 0 ? 'pos' : v < 0 ? 'neg' : '' });

// Datos para el gráfico (por día, una serie por año).
const datosGrafica = {
  dias: compDias.map((d) => d.nombre),
  anios: aniosOrden,
  noNaz: Object.fromEntries(aniosOrden.map((an) => [an, compDias.map((d) => d.porAnio[an]?.noNaz ?? null)])),
  noTotal: Object.fromEntries(aniosOrden.map((an) => [an, compDias.map((d) => d.porAnio[an]?.noTotal ?? null)])),
};

const title = `Comparativa de la Semana Santa de Sevilla por años (${aniosOrden.join(', ')}) | Open Data`;
const description =
  `Comparativa del conteo de la Semana Santa de Sevilla entre años (${aniosOrden.join(', ')}): evolución de ` +
  `nazarenos y participantes del cortejo por hermandad y por día.`;
---

<Base title={title} description={description} comparativaActiva={true}>
  <section class="hero">
    <div class="contenedor">
      <nav class="migas" aria-label="Migas de pan">
        <a href="/">Inicio</a> <span aria-hidden="true">›</span> <span>Comparativa</span>
      </nav>
      <h1>Comparativa entre años</h1>
      <p>
        Evolución del conteo de la Semana Santa de Sevilla por día y por hermandad. Un guion
        (<strong>—</strong>) significa que ese día/hermandad no se contó ese año.
      </p>

      <div class="controles">
        <span class="campo" style="gap:.4rem">
          Métrica
          <span class="segmento">
            <label><input type="radio" name="metrica" value="noNaz" checked /> Nazarenos</label>
            <label><input type="radio" name="metrica" value="noTotal" /> Cortejo total</label>
          </span>
        </span>
        <label class="campo">
          Comparar {aLatest} con
          <select id="selector-base">
            {basesPosibles.map((b) => <option value={b}>{b}</option>)}
          </select>
        </label>
      </div>
    </div>
  </section>

  <section class="panel contenedor">
    <div class="panel__cab"><h2>Por día</h2></div>
    <figure class="grafica grafica--ancha">
      <figcaption>Comparativa por día — <span id="titulo-metrica">nazarenos</span></figcaption>
      <div class="grafica__lienzo"><canvas id="grafica-comparativa" aria-label="Comparativa por día entre años"></canvas></div>
    </figure>

    <div class="tabla-wrap" style="margin-top:1.2rem">
      <table class="datos">
        <caption>Totales por día y año. La variación es {aLatest} respecto al año elegido.</caption>
        <thead>
          <tr>
            <th class="txt" scope="col">Día</th>
            {aniosOrden.map((an) => <th scope="col">{an}</th>)}
            <th scope="col">Var. {aLatest}/<span class="anio-base-lbl">{baseInicial}</span></th>
          </tr>
        </thead>
        <tbody>
          {compDias.map((d) => {
            const v = celdaVar(varDe(d.porAnio, 'noNaz', baseInicial));
            return (
              <tr>
                <td class="txt">{d.nombre}</td>
                {aniosOrden.map((an) => (
                  <td data-anio={an} data-naz={d.porAnio[an]?.noNaz ?? ''} data-total={d.porAnio[an]?.noTotal ?? ''}>
                    {d.porAnio[an] ? fmt(d.porAnio[an].noNaz) : '—'}
                  </td>
                ))}
                <td class={`var ${v.cls}`}>{v.txt}</td>
              </tr>
            );
          })}
        </tbody>
      </table>
    </div>
  </section>

  <section class="panel contenedor">
    <div class="panel__cab"><h2>Por hermandad</h2></div>
    <div class="tabla-wrap">
      <table class="datos">
        <caption>Cifras por hermandad y año, agrupadas por día. La variación es {aLatest} respecto al año elegido.</caption>
        <thead>
          <tr>
            <th class="txt" scope="col">Día</th>
            <th class="txt" scope="col">Hermandad</th>
            {aniosOrden.map((an) => <th scope="col">{an}</th>)}
            <th scope="col">Var. {aLatest}/<span class="anio-base-lbl">{baseInicial}</span></th>
          </tr>
        </thead>
        <tbody>
          {compHerms.map((h) => {
            const v = celdaVar(varDe(h.porAnio, 'noNaz', baseInicial));
            return (
              <tr>
                <td class="txt"><span class="pildora-dia">{h.diaNombre}</span></td>
                <td class="txt"><a href={`/${h.porAnio[aLatest] ? aLatest : aniosOrden.find((an) => h.porAnio[an])}/hermandad/${h.slug}/`}>{h.nombre}</a></td>
                {aniosOrden.map((an) => (
                  <td data-anio={an} data-naz={h.porAnio[an]?.noNaz ?? ''} data-total={h.porAnio[an]?.noTotal ?? ''}>
                    {h.porAnio[an] ? fmt(h.porAnio[an].noNaz) : '—'}
                  </td>
                ))}
                <td class={`var ${v.cls}`}>{v.txt}</td>
              </tr>
            );
          })}
        </tbody>
      </table>
    </div>
  </section>

  <script type="application/json" id="datos-comparativa" set:html={JSON.stringify(datosGrafica)}></script>
  <script>
    import { Chart, BarController, BarElement, CategoryScale, LinearScale, Tooltip, Legend } from 'chart.js';
    Chart.register(BarController, BarElement, CategoryScale, LinearScale, Tooltip, Legend);

    const datos = JSON.parse(document.getElementById('datos-comparativa').textContent);
    const PALETA = ['#5b2a86', '#c8a24a', '#3d8a6b', '#b5462f', '#2f6fb5'];
    const nf = new Intl.NumberFormat('es-ES', { useGrouping: 'always' });
    const pf = (v) => `${(v > 0 ? '+' : '')}${v.toLocaleString('es-ES', { minimumFractionDigits: 1, maximumFractionDigits: 1 })} %`;

    const A_LATEST = datos.anios[0];
    let metrica = 'noNaz';
    let base = datos.anios[1];

    const chart = new Chart(document.getElementById('grafica-comparativa'), {
      type: 'bar',
      data: {
        labels: datos.dias,
        datasets: datos.anios.map((an, i) => ({ label: String(an), data: datos[metrica][an], backgroundColor: PALETA[i % PALETA.length] })),
      },
      options: {
        responsive: true, maintainAspectRatio: false,
        plugins: {
          legend: { position: 'bottom' },
          tooltip: { callbacks: { label: (c) => `${c.dataset.label}: ${c.parsed.y == null ? '—' : nf.format(c.parsed.y)}` } },
        },
        scales: { y: { beginAtZero: true, ticks: { callback: (v) => nf.format(v) } } },
      },
    });

    const tituloMetrica = document.getElementById('titulo-metrica');
    const selBase = document.getElementById('selector-base');

    function aplicar() {
      const cd = metrica === 'noNaz' ? 'naz' : 'total';
      document.querySelectorAll('td[data-anio]').forEach((td) => {
        const v = td.dataset[cd];
        td.textContent = v === '' ? '—' : nf.format(+v);
      });
      document.querySelectorAll('td.var').forEach((td) => {
        const tr = td.closest('tr');
        const a = tr.querySelector(`td[data-anio="${A_LATEST}"]`)?.dataset[cd];
        const b = tr.querySelector(`td[data-anio="${base}"]`)?.dataset[cd];
        td.classList.remove('pos', 'neg');
        if (a == null || a === '' || b == null || b === '' || +b === 0) { td.textContent = '—'; return; }
        const vv = ((+a - +b) / +b) * 100;
        td.textContent = pf(vv);
        td.classList.add(vv > 0 ? 'pos' : vv < 0 ? 'neg' : '');
      });
      chart.data.datasets.forEach((ds, i) => { ds.data = datos[metrica][datos.anios[i]]; });
      chart.update();
      document.querySelectorAll('.anio-base-lbl').forEach((el) => { el.textContent = base; });
      tituloMetrica.textContent = metrica === 'noNaz' ? 'nazarenos' : 'cortejo total';
    }

    document.querySelectorAll('input[name="metrica"]').forEach((r) => {
      r.addEventListener('change', () => { if (r.checked) { metrica = r.value; aplicar(); } });
    });
    selBase.addEventListener('change', () => { base = Number(selBase.value); aplicar(); });

    aplicar();
  </script>

  <section class="panel contenedor">
    <FuentesResumen fuentes={fuentesComparativa} />
  </section>
</Base>
