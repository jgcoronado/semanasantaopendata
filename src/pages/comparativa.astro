---
import Base from '../layouts/Base.astro';
import { anios, getComparativaDias, getComparativaHermandades, fmt, fmtPct, variacion } from '../lib/datos.js';

const aniosOrden = anios.map((a) => a.anio); // descendente, p. ej. [2026, 2025]
const aLatest = aniosOrden[0];
const aPrev = aniosOrden[1];

const compDias = getComparativaDias();
const compHerms = getComparativaHermandades();

// Variación interanual (último año disponible vs anterior) para una métrica.
const varDe = (porAnio, metrica) => variacion(porAnio[aLatest]?.[metrica] ?? null, porAnio[aPrev]?.[metrica] ?? null);
const celdaVar = (v) => (v == null ? { txt: '—', cls: '' } : { txt: (v > 0 ? '+' : '') + fmtPct(v), cls: v > 0 ? 'pos' : v < 0 ? 'neg' : '' });

// Datos para el gráfico (por día, una serie por año).
const datosGrafica = {
  dias: compDias.map((d) => d.nombre),
  anios: aniosOrden,
  noNaz: Object.fromEntries(aniosOrden.map((an) => [an, compDias.map((d) => d.porAnio[an]?.noNaz ?? null)])),
  noTotal: Object.fromEntries(aniosOrden.map((an) => [an, compDias.map((d) => d.porAnio[an]?.noTotal ?? null)])),
};

const title = `Comparativa de la Semana Santa de Sevilla por años (${aniosOrden.join(', ')}) | Open Data`;
const description =
  `Comparativa del conteo de la Semana Santa de Sevilla entre años (${aniosOrden.join(', ')}): evolución de ` +
  `nazarenos y participantes del cortejo por hermandad y por día.`;
---

<Base title={title} description={description} comparativaActiva={true}>
  <section class="hero">
    <div class="contenedor">
      <nav class="migas" aria-label="Migas de pan">
        <a href="/">Inicio</a> <span aria-hidden="true">›</span> <span>Comparativa</span>
      </nav>
      <h1>Comparativa entre años</h1>
      <p>
        Evolución del conteo de la Semana Santa de Sevilla por día y por hermandad. La variación
        compara <strong>{aLatest}</strong> con <strong>{aPrev}</strong>. Un guion (<strong>—</strong>)
        significa que ese día/hermandad no se contó ese año.
      </p>

      <div class="controles" role="group" aria-label="Métrica">
        <span class="campo" style="gap:.4rem">
          Métrica
          <span class="segmento">
            <label><input type="radio" name="metrica" value="noNaz" checked /> Nazarenos</label>
            <label><input type="radio" name="metrica" value="noTotal" /> Cortejo total</label>
          </span>
        </span>
      </div>
    </div>
  </section>

  <section class="panel contenedor">
    <div class="panel__cab"><h2>Por día</h2></div>
    <figure class="grafica grafica--ancha">
      <figcaption>Comparativa por día — <span id="titulo-metrica">nazarenos</span></figcaption>
      <div class="grafica__lienzo"><canvas id="grafica-comparativa" aria-label="Comparativa por día entre años"></canvas></div>
    </figure>

    <div class="tabla-wrap" style="margin-top:1.2rem">
      <table class="datos">
        <caption>Totales por día y año. La variación es {aLatest} respecto a {aPrev}.</caption>
        <thead>
          <tr>
            <th class="txt" scope="col">Día</th>
            {aniosOrden.map((an) => <th scope="col">{an}</th>)}
            <th scope="col">Var. {aLatest}/{aPrev}</th>
          </tr>
        </thead>
        <tbody>
          {compDias.map((d) => {
            const v = celdaVar(varDe(d.porAnio, 'noNaz'));
            return (
              <tr>
                <td class="txt">{d.nombre}</td>
                {aniosOrden.map((an) => (
                  <td data-naz={d.porAnio[an]?.noNaz ?? ''} data-total={d.porAnio[an]?.noTotal ?? ''}>
                    {d.porAnio[an] ? fmt(d.porAnio[an].noNaz) : '—'}
                  </td>
                ))}
                <td class={`var ${v.cls}`} data-vnaz={varDe(d.porAnio, 'noNaz') ?? ''} data-vtotal={varDe(d.porAnio, 'noTotal') ?? ''}>{v.txt}</td>
              </tr>
            );
          })}
        </tbody>
      </table>
    </div>
  </section>

  <section class="panel contenedor">
    <div class="panel__cab"><h2>Por hermandad</h2></div>
    <div class="tabla-wrap">
      <table class="datos">
        <caption>Cifras por hermandad y año, agrupadas por día. La variación es {aLatest} respecto a {aPrev}.</caption>
        <thead>
          <tr>
            <th class="txt" scope="col">Día</th>
            <th class="txt" scope="col">Hermandad</th>
            {aniosOrden.map((an) => <th scope="col">{an}</th>)}
            <th scope="col">Var. {aLatest}/{aPrev}</th>
          </tr>
        </thead>
        <tbody>
          {compHerms.map((h) => {
            const v = celdaVar(varDe(h.porAnio, 'noNaz'));
            return (
              <tr>
                <td class="txt"><span class="pildora-dia">{h.diaNombre}</span></td>
                <td class="txt">{h.nombre}</td>
                {aniosOrden.map((an) => (
                  <td data-naz={h.porAnio[an]?.noNaz ?? ''} data-total={h.porAnio[an]?.noTotal ?? ''}>
                    {h.porAnio[an] ? fmt(h.porAnio[an].noNaz) : '—'}
                  </td>
                ))}
                <td class={`var ${v.cls}`} data-vnaz={varDe(h.porAnio, 'noNaz') ?? ''} data-vtotal={varDe(h.porAnio, 'noTotal') ?? ''}>{v.txt}</td>
              </tr>
            );
          })}
        </tbody>
      </table>
    </div>
  </section>

  <script type="application/json" id="datos-comparativa" set:html={JSON.stringify(datosGrafica)}></script>
  <script>
    import { Chart, BarController, BarElement, CategoryScale, LinearScale, Tooltip, Legend } from 'chart.js';
    Chart.register(BarController, BarElement, CategoryScale, LinearScale, Tooltip, Legend);

    const datos = JSON.parse(document.getElementById('datos-comparativa').textContent);
    const PALETA = ['#5b2a86', '#c8a24a', '#3d8a6b', '#b5462f', '#2f6fb5'];
    const nf = new Intl.NumberFormat('es-ES', { useGrouping: 'always' });
    const pf = (v) => `${(v > 0 ? '+' : '')}${v.toLocaleString('es-ES', { minimumFractionDigits: 1, maximumFractionDigits: 1 })} %`;

    let metrica = 'noNaz';

    const chart = new Chart(document.getElementById('grafica-comparativa'), {
      type: 'bar',
      data: {
        labels: datos.dias,
        datasets: datos.anios.map((an, i) => ({
          label: String(an),
          data: datos[metrica][an],
          backgroundColor: PALETA[i % PALETA.length],
        })),
      },
      options: {
        responsive: true, maintainAspectRatio: false,
        plugins: {
          legend: { position: 'bottom' },
          tooltip: { callbacks: { label: (c) => `${c.dataset.label}: ${c.parsed.y == null ? '—' : nf.format(c.parsed.y)}` } },
        },
        scales: { y: { beginAtZero: true, ticks: { callback: (v) => nf.format(v) } } },
      },
    });

    const tituloMetrica = document.getElementById('titulo-metrica');

    function aplicar(m) {
      metrica = m;
      const claveData = m === 'noNaz' ? 'naz' : 'total';
      const claveVar = m === 'noNaz' ? 'vnaz' : 'vtotal';
      document.querySelectorAll('td[data-naz]').forEach((td) => {
        const v = td.dataset[claveData];
        td.textContent = v === '' ? '—' : nf.format(+v);
      });
      document.querySelectorAll('td.var').forEach((td) => {
        const v = td.dataset[claveVar];
        td.classList.remove('pos', 'neg');
        if (v === '') { td.textContent = '—'; return; }
        const n = parseFloat(v);
        td.textContent = pf(n);
        td.classList.add(n > 0 ? 'pos' : n < 0 ? 'neg' : '');
      });
      chart.data.datasets.forEach((ds, i) => { ds.data = datos[m][datos.anios[i]]; });
      chart.update();
      tituloMetrica.textContent = m === 'noNaz' ? 'nazarenos' : 'cortejo total';
    }

    document.querySelectorAll('input[name="metrica"]').forEach((r) => {
      r.addEventListener('change', () => { if (r.checked) aplicar(r.value); });
    });
  </script>
</Base>
