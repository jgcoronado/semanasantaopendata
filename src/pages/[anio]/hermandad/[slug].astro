---
import Base from '../../../layouts/Base.astro';
import GraficasHermandad from '../../../components/GraficasHermandad.astro';
import { anios, getAnio, fmt, fmtPct, fmtDur, variacion, hayHorarios, getHorariosAnio } from '../../../lib/datos.js';

export function getStaticPaths() {
  const paths = [];
  for (const a of anios) {
    for (const r of getAnio(a.anio).registros) {
      paths.push({ params: { anio: a.slug, slug: r.slug } });
    }
  }
  return paths;
}

const { anio, slug } = Astro.params;
const anioNum = Number(anio);
const { registros } = getAnio(anioNum);

const r = registros.find((x) => x.slug === slug);
const hermsDia = registros.filter((x) => x.diaSlug === r.diaSlug);

const rankNaz = [...hermsDia].sort((a, b) => b.noNaz - a.noNaz).findIndex((x) => x.slug === slug) + 1;
const rankTotal = [...hermsDia].sort((a, b) => b.noTotal - a.noTotal).findIndex((x) => x.slug === slug) + 1;

// La misma hermandad en otros años (donde tenga datos).
const enOtrosAnios = anios
  .filter((a) => a.anio !== anioNum)
  .map((a) => ({ anio: a.anio, presente: getAnio(a.anio).registros.some((x) => x.slug === slug) }))
  .filter((x) => x.presente);

// Esta hermandad en todos los años (ascendente) para la tabla de evolución y las gráficas.
const porAnioAsc = [...anios]
  .sort((a, b) => a.anio - b.anio)
  .map((a) => {
    const d = getAnio(a.anio);
    const reg = d.registros.find((x) => x.slug === slug);
    if (!reg) return null;
    const tot = d.totalesPorDia.find((t) => t.slug === reg.diaSlug);
    return {
      anio: a.anio,
      nazarenos: reg.nazarenos, penitentes: reg.penitentes, acolitos: reg.acolitos,
      monaguillos: reg.monaguillos, acompCortejo: reg.acompCortejo,
      noNaz: reg.noNaz, noTotal: reg.noTotal, pctNaz: reg.pctNaz, pctTotal: reg.pctTotal,
      diaNoNaz: tot.noNaz, diaNoTotal: tot.noTotal,
    };
  })
  .filter(Boolean);

const filasAnios = porAnioAsc.map((x, i) => {
  const prev = porAnioAsc[i - 1];
  return { ...x, varNaz: prev ? variacion(x.noNaz, prev.noNaz) : null, varTotal: prev ? variacion(x.noTotal, prev.noTotal) : null };
});

const celdaVar = (v) => (v == null ? { txt: '—', cls: '' } : { txt: (v > 0 ? '+' : '') + fmtPct(v), cls: v > 0 ? 'pos' : v < 0 ? 'neg' : '' });

// Horario oficial de esta hermandad en el año mostrado (si existe).
const horario = hayHorarios(anioNum) ? getHorariosAnio(anioNum).registros.find((x) => x.id_hdad === r.id_hdad) : null;
const itinerario = horario
  ? [
      { punto: 'Salida', hora: horario.horas.salida },
      { punto: 'La Campana', hora: horario.horas.campana },
      { punto: 'Sierpes', hora: horario.horas.sierpes },
      { punto: 'Plaza S. Francisco', hora: horario.horas.plaza },
      { punto: 'Catedral', hora: horario.horas.catedral },
      { punto: 'Últ. paso (Catedral)', hora: horario.horas.ultimoPasoFuera },
      { punto: 'Entrada', hora: horario.horas.entrada, sig: horario.entradaMin >= 1440 },
    ]
  : [];

const metricasDesglose = [
  { etiqueta: 'Nazarenos', key: 'nazarenos' },
  { etiqueta: 'Penitentes', key: 'penitentes' },
  { etiqueta: 'Total nazarenos', key: 'noNaz', fuerte: true },
  { etiqueta: 'Acólitos', key: 'acolitos' },
  { etiqueta: 'Monaguillos', key: 'monaguillos' },
  { etiqueta: 'Acompañamiento', key: 'acompCortejo' },
  { etiqueta: 'Total cortejo', key: 'noTotal', fuerte: true },
];

const title = `${r.nombre} (${r.diaNombre}) ${anio} · nazarenos y cortejo | Semana Santa Open Data`;
const description =
  `La hermandad ${r.nombre} procesionó el ${r.diaNombre} de ${anio} con ${fmt(r.noNaz)} nazarenos ` +
  `(${fmtPct(r.pctNaz)} de su día) y ${fmt(r.noTotal)} participantes en total.`;

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Observation',
  name: `${r.nombre} — conteo Semana Santa de Sevilla ${anio}`,
  url: new URL(`/${anio}/hermandad/${slug}/`, Astro.site).href,
  measuredProperty: 'Nazarenos y participantes del cortejo',
  observationDate: anio,
  description,
};
---

<Base title={title} description={description} jsonLd={jsonLd} anioActivo={anioNum}>
  <section class="hero">
    <div class="contenedor">
      <nav class="migas" aria-label="Migas de pan">
        <a href="/">Inicio</a> <span aria-hidden="true">›</span>
        <a href={`/${anio}/`}>{anio}</a> <span aria-hidden="true">›</span>
        <a href={`/${anio}/dia/${r.diaSlug}/`}>{r.diaNombre}</a> <span aria-hidden="true">›</span>
        <span>{r.nombre}</span>
      </nav>
      <h1>{r.nombre} <span class="h1-anio">{anio}</span></h1>
      <p>
        Procesionó el <a href={`/${anio}/dia/${r.diaSlug}/`}>{r.diaNombre}</a> de la Semana Santa de
        Sevilla {anio}. Es la <strong>{rankNaz}.ª</strong> de su día por número de nazarenos y la
        <strong>{rankTotal}.ª</strong> por cortejo total (de {hermsDia.length}).
        {enOtrosAnios.length > 0 && (
          <span> Ver esta hermandad en {enOtrosAnios.map((o, i) => (<>{i > 0 ? ', ' : ' '}<a href={`/${o.anio}/hermandad/${slug}/`}>{o.anio}</a></>))}, o en la <a href="/comparativa/">comparativa</a>.</span>
        )}
      </p>

      <div class="kpis">
        <div class="kpi">
          <div class="kpi__num">{fmt(r.noNaz)}</div>
          <div class="kpi__lbl">Nazarenos</div>
        </div>
        <div class="kpi">
          <div class="kpi__num">{fmtPct(r.pctNaz)}</div>
          <div class="kpi__lbl">de los nazarenos del día</div>
        </div>
        <div class="kpi">
          <div class="kpi__num">{fmt(r.noTotal)}</div>
          <div class="kpi__lbl">Participantes en el cortejo</div>
        </div>
        <div class="kpi">
          <div class="kpi__num">{fmtPct(r.pctTotal)}</div>
          <div class="kpi__lbl">del cortejo del día</div>
        </div>
      </div>
    </div>
  </section>

  {horario && (
    <section class="panel contenedor">
      <div class="panel__cab"><h2>Horario oficial {anio}</h2></div>
      <p class="descargas-intro">
        Duración <strong>{fmtDur(horario.duracionMin)}</strong> · en Carrera Oficial
        <strong>{fmtDur(horario.carreraOficialMin)}</strong>
        {horario.partPorHora != null && <> · <strong>{fmt(horario.partPorHora)}</strong> participantes/hora</>}.
      </p>
      <ul class="itinerario">
        {itinerario.map((it) => (
          <li>
            <span class="it-punto">{it.punto}</span>
            <span class="it-hora">{it.hora}{it.sig && <span class="dia-sig"> +1</span>}</span>
          </li>
        ))}
      </ul>
      <nav class="dia-nav" aria-label="Más">
        <a class="dia-nav__a dia-nav__der" href={`/${anio}/horarios/`}>Ver todos los horarios →</a>
      </nav>
    </section>
  )}

  <section class="panel contenedor">
    <div class="panel__cab"><h2>Desglose por año</h2></div>
    <div class="tabla-wrap">
      <table class="datos">
        <caption>Composición completa de {r.nombre} por año (la columna de {anio}, el año que estás viendo, va resaltada).</caption>
        <thead>
          <tr>
            <th class="txt" scope="col">Concepto</th>
            {porAnioAsc.map((x) => <th scope="col" class={x.anio === anioNum ? 'col-actual' : ''}>{x.anio}</th>)}
          </tr>
        </thead>
        <tbody>
          {metricasDesglose.map((m) => (
            <tr>
              <td class="txt">{m.etiqueta}</td>
              {porAnioAsc.map((x) => (
                <td class={`${m.fuerte ? 'fuerte' : ''} ${x.anio === anioNum ? 'col-actual' : ''}`.trim()}>{fmt(x[m.key])}</td>
              ))}
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </section>

  <section class="panel contenedor">
    <div class="panel__cab"><h2>Datos por año</h2></div>
    <div class="tabla-wrap">
      <table class="datos">
        <caption>Cifras de {r.nombre} por año. La variación compara cada año con el anterior disponible.</caption>
        <thead>
          <tr>
            <th class="txt" scope="col">Año</th>
            <th scope="col">Nazarenos</th>
            <th scope="col">Var.</th>
            <th scope="col">Cortejo</th>
            <th scope="col">Var.</th>
            <th scope="col">% día (naz.)</th>
            <th scope="col">% día (cortejo)</th>
          </tr>
        </thead>
        <tbody>
          {filasAnios.map((f) => {
            const vn = celdaVar(f.varNaz);
            const vt = celdaVar(f.varTotal);
            return (
              <tr class={f.anio === anioNum ? 'fila-resaltada' : ''}>
                <td class="txt fuerte"><a href={`/${f.anio}/hermandad/${slug}/`}>{f.anio}</a></td>
                <td>{fmt(f.noNaz)}</td>
                <td class={`var ${vn.cls}`}>{vn.txt}</td>
                <td>{fmt(f.noTotal)}</td>
                <td class={`var ${vt.cls}`}>{vt.txt}</td>
                <td>{fmtPct(f.pctNaz)}</td>
                <td>{fmtPct(f.pctTotal)}</td>
              </tr>
            );
          })}
        </tbody>
      </table>
    </div>

    <GraficasHermandad nombre={r.nombre} datos={porAnioAsc} />

    <nav class="dia-nav" aria-label="Más">
      <a class="dia-nav__a" href={`/${anio}/dia/${r.diaSlug}/`}>← Todas las hermandades del {r.diaNombre}</a>
      <a class="dia-nav__a dia-nav__der" href="/comparativa/">Comparar años →</a>
    </nav>
  </section>
</Base>
