---
import Base from '../../../layouts/Base.astro';
import CarreraOficialTabla from '../../../components/CarreraOficialTabla.astro';
import CarreraOficialGraficas from '../../../components/CarreraOficialGraficas.astro';
import FuentesResumen from '../../../components/FuentesResumen.astro';
import { aniosConPasoReal, getPasoReal, fmt, getFuentesAnio } from '../../../lib/datos.js';

export function getStaticPaths() {
  return aniosConPasoReal.map((a) => ({ params: { anio: a.slug } }));
}

const { anio } = Astro.params;
const anioNum = Number(anio);
const { registros, diasPresentes } = getPasoReal(anioNum);
const fuentesPagina = getFuentesAnio(anioNum, ['nazarenos', 'paso_real']);

const masRetrasada = registros.reduce((a, b) => (b.retrasoRealCampana > a.retrasoRealCampana ? b : a));
const masPuntual   = registros.reduce((a, b) => (b.retrasoRealCampana < a.retrasoRealCampana ? b : a));

const acumuladoFinalPorDia = diasPresentes.map((d) => {
  const regsDelDia = registros.filter((r) => r.diaSlug === d.slug);
  const ultimo = regsDelDia[regsDelDia.length - 1];
  return { dia: d.nombre, acumulado: ultimo?.acumuladoCampana ?? 0 };
});
const diaMaxAcumulado = acumuladoFinalPorDia.reduce((a, b) => (b.acumulado > a.acumulado ? b : a), { dia: '—', acumulado: 0 });

const totalRecuperado = registros.reduce((s, r) => s + (r.tiempoRecortado > 0 ? r.tiempoRecortado : 0), 0);

const fmtMin = (n) => {
  if (n == null) return '—';
  const abs = Math.abs(n);
  const h = Math.floor(abs / 60);
  const m = abs % 60;
  const str = h > 0 ? `${h} h ${String(m).padStart(2, '0')} min` : `${m} min`;
  return (n > 0 ? '+' : n < 0 ? '−' : '') + str;
};

const title = `Carrera Oficial ${anio}: tiempos reales de paso | Semana Santa de Sevilla Open Data`;
const description =
  `Tiempos reales de paso por La Campana y La Catedral en la Semana Santa de Sevilla ${anio}. ` +
  `Retrasos acumulados, puntualidad de cada hermandad y análisis del tiempo recuperado en carrera.`;

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Dataset',
  name: `Carrera Oficial ${anio}: tiempos reales de paso`,
  description,
  url: new URL(`/${anio}/carrera-oficial/`, Astro.site).href,
  inLanguage: 'es',
  isPartOf: { '@type': 'Dataset', name: `Conteo de la Semana Santa de Sevilla ${anio}`, url: new URL(`/${anio}/`, Astro.site).href },
  temporalCoverage: anio,
  spatialCoverage: { '@type': 'Place', name: 'Sevilla, España' },
  isAccessibleForFree: true,
};
---

<Base title={title} description={description} jsonLd={jsonLd} anioActivo={anioNum} carreraActiva={true}>
  <section class="hero hero--ancho">
    <div class="contenedor">
      <nav class="migas" aria-label="Migas de pan">
        <a href="/">Inicio</a> <span aria-hidden="true">›</span>
        <a href={`/${anio}/`}>{anio}</a> <span aria-hidden="true">›</span> <span>Carrera oficial</span>
      </nav>
      <h1 class="hero__titulo-ancho">Carrera oficial {anio} — tiempos reales</h1>
      <p class="hero__desc-ancho">
        Tiempos <strong>reales</strong> de paso de la cruz de guía y el último paso de cada hermandad
        por <strong>La Campana</strong>. El acumulado mide cuántos minutos lleva de retraso (o adelanto)
        la carrera en ese momento respecto al horario oficial. Duración real comparada con la programada
        y contribución individual de cada hermandad al retraso del día.
      </p>

      <div class="kpis">
        <div class="kpi">
          <div class="kpi__num">{fmt(registros.length)}</div>
          <div class="kpi__lbl">Hermandades</div>
        </div>
        {diaMaxAcumulado.acumulado > 0 && (
          <div class="kpi">
            <div class="kpi__num">{fmtMin(diaMaxAcumulado.acumulado)}</div>
            <div class="kpi__lbl">Máx. acumulado — {diaMaxAcumulado.dia}</div>
          </div>
        )}
        <div class="kpi">
          <div class="kpi__num" style="font-size:1.1rem">{masRetrasada.nombre}</div>
          <div class="kpi__lbl">Mayor retraso en Campana — {fmtMin(masRetrasada.retrasoRealCampana)}</div>
        </div>
        <div class="kpi">
          <div class="kpi__num" style="font-size:1.1rem">{masPuntual.nombre}</div>
          <div class="kpi__lbl">Más rápida en Campana — {fmtMin(masPuntual.retrasoRealCampana)}</div>
        </div>
      </div>
    </div>
  </section>

  <section class="panel contenedor" id="tabla-carrera-sec">
    <div class="panel__cab"><h2>Tiempos por hermandad</h2></div>
    <CarreraOficialTabla registros={registros} dias={diasPresentes} anio={anio} />
  </section>

  <CarreraOficialGraficas registros={registros} dias={diasPresentes} />

  <section class="panel contenedor">
    <FuentesResumen fuentes={fuentesPagina} />
  </section>
</Base>

<style>
  .hero--ancho { background: linear-gradient(135deg, var(--morado-osc) 0%, var(--morado) 100%); color: var(--blanco); padding-block: clamp(2.5rem, 6vw, 4rem) 2rem; }
  .hero--ancho .migas a { color: rgba(255,255,255,0.75); }
  .hero--ancho .migas { color: rgba(255,255,255,0.6); }
  .hero__titulo-ancho { font-size: clamp(1.9rem, 5vw, 3.2rem); line-height: 1.1; margin: 0 0 0.7rem; max-width: 100%; color: var(--blanco); }
  .hero__desc-ancho { max-width: 100%; font-size: clamp(1rem, 2vw, 1.18rem); color: rgba(255,255,255,0.85); margin: 0; line-height: 1.6; }
  .hero__desc-ancho strong { color: var(--blanco); }
  .hero--ancho .kpi { background: rgba(255,255,255,0.12); border-color: rgba(255,255,255,0.2); }
  .hero--ancho .kpi__num { color: var(--oro); }
  .hero--ancho .kpi__lbl { color: rgba(255,255,255,0.75); }
</style>
