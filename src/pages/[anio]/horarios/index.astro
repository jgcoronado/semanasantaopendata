---
import Base from '../../../layouts/Base.astro';
import HorariosTabla from '../../../components/HorariosTabla.astro';
import HorariosGraficas from '../../../components/HorariosGraficas.astro';
import FuentesResumen from '../../../components/FuentesResumen.astro';
import { aniosConHorarios, getHorariosAnio, fmt, fmtDur, getFuentesAnio } from '../../../lib/datos.js';

export function getStaticPaths() {
  return aniosConHorarios.map((a) => ({ params: { anio: a.slug } }));
}

const { anio } = Astro.params;
const anioNum = Number(anio);
const { registros, diasPresentes } = getHorariosAnio(anioNum);
const fuentesPagina = getFuentesAnio(anioNum, ['horarios']);

const masLarga = registros.reduce((a, b) => (b.duracionMin > a.duracionMin ? b : a));
const masCorta = registros.reduce((a, b) => (b.duracionMin < a.duracionMin ? b : a));
const duracionMedia = Math.round(registros.reduce((s, r) => s + r.duracionMin, 0) / registros.length);

const title = `Horarios oficiales de la Semana Santa de Sevilla ${anio} | Open Data`;
const description =
  `Horarios oficiales ${anio} de las cofradías de Sevilla: salida, recorrido por la Carrera Oficial y entrada, ` +
  `con duración, tiempo en carrera oficial y participantes por hora. Tabla y gráficas.`;

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Dataset',
  name: `Horarios oficiales de la Semana Santa de Sevilla ${anio}`,
  description,
  url: new URL(`/${anio}/horarios/`, Astro.site).href,
  inLanguage: 'es',
  isPartOf: { '@type': 'Dataset', name: `Conteo de la Semana Santa de Sevilla ${anio}`, url: new URL(`/${anio}/`, Astro.site).href },
  temporalCoverage: anio,
  spatialCoverage: { '@type': 'Place', name: 'Sevilla, España' },
  isAccessibleForFree: true,
};
---

<Base title={title} description={description} jsonLd={jsonLd} anioActivo={anioNum}>
  <section class="anio-cab contenedor">
    <div class="anio-cab__top">
      <div>
        <h1 class="anio-cab__titulo"><a href={`/${anio}/`}>{anio}</a> — Horarios oficiales</h1>
      </div>
      <div class="anio-cab__kpis">
        <span class="kpi-mini"><strong>{fmt(registros.length)}</strong> cofradías</span>
        <span class="kpi-mini">media <strong>{fmtDur(duracionMedia)}</strong></span>
        <span class="kpi-mini">más larga: <strong>{masLarga.nombre}</strong> ({fmtDur(masLarga.duracionMin)})</span>
      </div>
    </div>
    <div class="anio-cab__links">
      <a href={`/${anio}/`}>Nazarenos</a>
      <a href={`/${anio}/horarios/`} class="activo">Horarios</a>
      <a href={`/${anio}/analisis/`}>Análisis</a>
    </div>
  </section>

  <section class="panel contenedor" id="tabla-horarios-sec">
    <HorariosTabla registros={registros} dias={diasPresentes} anio={anio} />
  </section>

  <HorariosGraficas registros={registros} dias={diasPresentes} />

  <section class="panel contenedor">
    <FuentesResumen fuentes={fuentesPagina} />
  </section>
</Base>
