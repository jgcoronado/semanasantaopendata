---
import Base from '../../../layouts/Base.astro';
import TablaNazarenos from '../../../components/TablaNazarenos.astro';
import ComposicionDia from '../../../components/ComposicionDia.astro';
import HorariosTabla from '../../../components/HorariosTabla.astro';
import HorariosGraficas from '../../../components/HorariosGraficas.astro';
import GraficasAnalisis from '../../../components/GraficasAnalisis.astro';
import CarreraOficialTabla from '../../../components/CarreraOficialTabla.astro';
import CarreraOficialGraficas from '../../../components/CarreraOficialGraficas.astro';
import FuentesResumen from '../../../components/FuentesResumen.astro';
import {
  anios, aniosConHorarios, hayPasoReal,
  getAnio, getHorariosAnio, getCruceNazarenosHorarios, getHorariosEnCalle, getPasoReal,
  fmt, getFuentesAnio,
} from '../../../lib/datos.js';

export function getStaticPaths() {
  const paths = [];
  for (const a of anios) {
    for (const d of getAnio(a.anio).diasPresentes) {
      paths.push({ params: { anio: a.slug, dia: d.slug } });
    }
  }
  return paths;
}

const { anio, dia } = Astro.params;
const anioNum = Number(anio);
const { registros, diasPresentes, totalesPorDia } = getAnio(anioNum);

const diaInfo = diasPresentes.find((d) => d.slug === dia);
const totales = totalesPorDia.find((t) => t.slug === dia);
const regs = registros.filter((r) => r.diaSlug === dia);

const idx = diasPresentes.findIndex((d) => d.slug === dia);
const anterior = diasPresentes[idx - 1];
const siguiente = diasPresentes[idx + 1];

const tieneHorarios = aniosConHorarios.some((h) => h.anio === anioNum);
const tienePasoReal = hayPasoReal(anioNum);

// --- Horarios del día ---
let horariosRegistros = [];
if (tieneHorarios) {
  horariosRegistros = getHorariosAnio(anioNum).registros.filter((r) => r.diaSlug === dia);
}

// --- Análisis del día ---
let analisisRegistros = [];
let analisisSinDatos = [];
let porDia = {};
let comparativaRows = [];
let comparativaAnio = null;
if (tieneHorarios) {
  const cruceData = getCruceNazarenosHorarios(anioNum);
  const todosDelDia = cruceData.registros.filter((r) => r.diaSlug === dia);
  analisisRegistros = todosDelDia.filter((r) => r.incidencia === null);
  analisisSinDatos = todosDelDia.filter((r) => r.incidencia !== null);
  const enCalle = getHorariosEnCalle(anioNum).porDia;
  if (enCalle[dia]) porDia = { [dia]: enCalle[dia] };

  const anioAnterior = aniosConHorarios.find((a) => a.anio < anioNum);
  if (anioAnterior) {
    comparativaAnio = anioAnterior.anio;
    const otroRegistros = getCruceNazarenosHorarios(anioAnterior.anio).registros;
    const otroMap = new Map(otroRegistros.map((r) => [r.id_hdad, r]));
    comparativaRows = analisisRegistros.map((r) => {
      const otro = otroMap.get(r.id_hdad);
      const otroSinDatos = otro?.incidencia === 'sin_datos';
      return {
        nombre:          r.nombre,
        diaNombre:       r.diaNombre,
        diaOrden:        r.diaOrden,
        noTotal:         r.noTotal,
        duracionMin:     r.duracionMin,
        otroNoTotal:     otroSinDatos || !otro ? null : otro.noTotal,
        otroDuracionMin: otroSinDatos || !otro ? null : otro.duracionMin,
        otroSinDatos,
      };
    });
  }
}

// --- Carrera oficial del día ---
let pasoRealRegistros = [];
if (tienePasoReal) {
  pasoRealRegistros = getPasoReal(anioNum).registros.filter((r) => r.diaSlug === dia);
}

// --- Fuentes ---
const fuentesPagina = getFuentesAnio(anioNum, [
  'nazarenos',
  ...(tieneHorarios ? ['horarios'] : []),
  ...(tienePasoReal ? ['paso_real'] : []),
]);

const totalDia = { hermandades: totales.hermandades, noNaz: totales.noNaz, noTotal: totales.noTotal };

const title = `Nazarenos del ${diaInfo.nombre} ${anio} · Semana Santa de Sevilla | Open Data`;
const description =
  `Conteo del ${diaInfo.nombre} de la Semana Santa de Sevilla ${anio}: ${fmt(totales.noNaz)} nazarenos y ` +
  `${fmt(totales.noTotal)} participantes en el cortejo, repartidos en ${totales.hermandades} hermandades.`;

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Dataset',
  name: `Conteo del ${diaInfo.nombre} — Semana Santa de Sevilla ${anio}`,
  description,
  url: new URL(`/${anio}/dia/${dia}/`, Astro.site).href,
  inLanguage: 'es',
  isPartOf: { '@type': 'Dataset', name: `Conteo de la Semana Santa de Sevilla ${anio}`, url: new URL(`/${anio}/`, Astro.site).href },
  temporalCoverage: anio,
  spatialCoverage: { '@type': 'Place', name: 'Sevilla, España' },
  isAccessibleForFree: true,
};
---

<Base title={title} description={description} jsonLd={jsonLd} anioActivo={anioNum}>
  <section class="anio-cab contenedor">
    <div class="anio-cab__top">
      <div>
        <h1 class="anio-cab__titulo"><a href={`/${anio}/`}>{anio}</a> — {diaInfo.nombre}</h1>
      </div>
      <div class="anio-cab__kpis">
        <span class="kpi-mini"><strong>{fmt(totales.hermandades)}</strong> hermandades</span>
        <span class="kpi-mini"><strong>{fmt(totales.noNaz)}</strong> nazarenos</span>
        <span class="kpi-mini"><strong>{fmt(totales.noTotal)}</strong> en el cortejo</span>
      </div>
    </div>
    <div class="anio-cab__links">
      {anterior && <a href={`/${anio}/dia/${anterior.slug}/`}>← {anterior.nombre}</a>}
      {siguiente && <a href={`/${anio}/dia/${siguiente.slug}/`}>{siguiente.nombre} →</a>}
      <a href={`/${anio}/`} class="anio-cab__dl">Todos los días</a>
    </div>
  </section>

  <!-- Tabla nazarenos del día -->
  <section class="panel contenedor">
    <TablaNazarenos registros={regs} totalGeneral={totalDia} anio={anio} conColumnaDia={false} conFiltroDia={false} />
    <FuentesResumen fuentes={fuentesPagina} />
  </section>

  <!-- Composición del día -->
  <ComposicionDia registros={regs} diaInfo={diaInfo} />

  <!-- Horarios del día -->
  {tieneHorarios && horariosRegistros.length > 0 && (
    <>
      <section class="panel contenedor" id="horarios">
        <div class="panel__cab"><h2>Horarios oficiales</h2></div>
        <HorariosTabla registros={horariosRegistros} dias={[diaInfo]} anio={anio} />
      </section>
      <HorariosGraficas registros={horariosRegistros} dias={[diaInfo]} />
    </>
  )}

  <!-- Análisis del día -->
  {tieneHorarios && analisisRegistros.length > 0 && (
    <GraficasAnalisis
      registros={analisisRegistros}
      sinDatos={analisisSinDatos}
      porDia={porDia}
      dias={[diaInfo]}
      comparativaRows={comparativaRows}
      comparativaAnio={comparativaAnio}
      anioActual={anioNum}
    />
  )}

  <!-- Carrera oficial del día -->
  {tienePasoReal && pasoRealRegistros.length > 0 && (
    <>
      <section class="panel contenedor" id="carrera-oficial">
        <div class="panel__cab"><h2>Carrera oficial — tiempos reales</h2></div>
        <CarreraOficialTabla registros={pasoRealRegistros} dias={[diaInfo]} anio={anio} />
      </section>
      <CarreraOficialGraficas registros={pasoRealRegistros} dias={[diaInfo]} />
    </>
  )}
</Base>
