---
import Base from '../../../layouts/Base.astro';
import TablaNazarenos from '../../../components/TablaNazarenos.astro';
import ComposicionDia from '../../../components/ComposicionDia.astro';
import FuentesResumen from '../../../components/FuentesResumen.astro';
import { anios, getAnio, fmt, getFuentesAnio } from '../../../lib/datos.js';

export function getStaticPaths() {
  const paths = [];
  for (const a of anios) {
    for (const d of getAnio(a.anio).diasPresentes) {
      paths.push({ params: { anio: a.slug, dia: d.slug } });
    }
  }
  return paths;
}

const { anio, dia } = Astro.params;
const anioNum = Number(anio);
const { registros, diasPresentes, totalesPorDia } = getAnio(anioNum);
const fuentesPagina = getFuentesAnio(anioNum, ['nazarenos']);

const diaInfo = diasPresentes.find((d) => d.slug === dia);
const totales = totalesPorDia.find((t) => t.slug === dia);
const regs = registros.filter((r) => r.diaSlug === dia);

const idx = diasPresentes.findIndex((d) => d.slug === dia);
const anterior = diasPresentes[idx - 1];
const siguiente = diasPresentes[idx + 1];

const title = `Nazarenos del ${diaInfo.nombre} ${anio} · Semana Santa de Sevilla | Open Data`;
const description =
  `Conteo del ${diaInfo.nombre} de la Semana Santa de Sevilla ${anio}: ${fmt(totales.noNaz)} nazarenos y ` +
  `${fmt(totales.noTotal)} participantes en el cortejo, repartidos en ${totales.hermandades} hermandades.`;

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Dataset',
  name: `Conteo del ${diaInfo.nombre} — Semana Santa de Sevilla ${anio}`,
  description,
  url: new URL(`/${anio}/dia/${dia}/`, Astro.site).href,
  inLanguage: 'es',
  isPartOf: { '@type': 'Dataset', name: `Conteo de la Semana Santa de Sevilla ${anio}`, url: new URL(`/${anio}/`, Astro.site).href },
  temporalCoverage: anio,
  spatialCoverage: { '@type': 'Place', name: 'Sevilla, España' },
  isAccessibleForFree: true,
};

const totalDia = { hermandades: totales.hermandades, noNaz: totales.noNaz, noTotal: totales.noTotal };
---

<Base title={title} description={description} jsonLd={jsonLd} anioActivo={anioNum}>
  <section class="anio-cab contenedor">
    <div class="anio-cab__top">
      <div>
        <h1 class="anio-cab__titulo"><a href={`/${anio}/`}>{anio}</a> — {diaInfo.nombre}</h1>
      </div>
      <div class="anio-cab__kpis">
        <span class="kpi-mini"><strong>{fmt(totales.hermandades)}</strong> hermandades</span>
        <span class="kpi-mini"><strong>{fmt(totales.noNaz)}</strong> nazarenos</span>
        <span class="kpi-mini"><strong>{fmt(totales.noTotal)}</strong> en el cortejo</span>
      </div>
    </div>
    <div class="anio-cab__links">
      {anterior && <a href={`/${anio}/dia/${anterior.slug}/`}>← {anterior.nombre}</a>}
      {siguiente && <a href={`/${anio}/dia/${siguiente.slug}/`}>{siguiente.nombre} →</a>}
      <a href={`/${anio}/`} class="anio-cab__dl">Todos los días</a>
    </div>
  </section>

  <section class="panel contenedor">
    <TablaNazarenos registros={regs} totalGeneral={totalDia} anio={anio} conColumnaDia={false} conFiltroDia={false} />
    <FuentesResumen fuentes={fuentesPagina} />
  </section>

  <ComposicionDia registros={regs} diaInfo={diaInfo} />
</Base>
