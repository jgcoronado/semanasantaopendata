---
import Base from '../../../layouts/Base.astro';
import GraficasAnalisis from '../../../components/GraficasAnalisis.astro';
import FuentesResumen from '../../../components/FuentesResumen.astro';
import {
  aniosConHorarios,
  getCruceNazarenosHorarios,
  getHorariosEnCalle,
  fmt,
  fmtDur,
  getFuentesAnio,
} from '../../../lib/datos.js';

export function getStaticPaths() {
  return aniosConHorarios.map((a) => ({ params: { anio: a.slug } }));
}

const { anio } = Astro.params;
const anioNum = Number(anio);
const { registros, diasPresentes } = getCruceNazarenosHorarios(anioNum);
const { porDia } = getHorariosEnCalle(anioNum);
const fuentesPagina = getFuentesAnio(anioNum, ['nazarenos', 'horarios']);

const conDatos  = registros.filter((r) => r.incidencia === null);
const sinDatos  = registros.filter((r) => r.incidencia !== null);

// KPIs
const durMedia   = Math.round(conDatos.reduce((s, r) => s + r.duracionMin, 0) / conDatos.length);

// Comparativa con el año anterior con horarios (si existe)
const anioAnterior = aniosConHorarios.find((a) => a.anio < anioNum);
let comparativaRows = [];
let comparativaAnio = null;

if (anioAnterior) {
  comparativaAnio = anioAnterior.anio;
  const otroRegistros = getCruceNazarenosHorarios(anioAnterior.anio).registros;
  const otroMap = new Map(otroRegistros.map((r) => [r.id_hdad, r]));

  comparativaRows = conDatos.map((r) => {
    const otro = otroMap.get(r.id_hdad);
    const otroSinDatos = otro?.incidencia === 'sin_datos';
    return {
      nombre:        r.nombre,
      diaNombre:     r.diaNombre,
      diaOrden:      r.diaOrden,
      noTotal:       r.noTotal,
      duracionMin:   r.duracionMin,
      otroNoTotal:   otroSinDatos || !otro ? null : otro.noTotal,
      otroDuracionMin: otroSinDatos || !otro ? null : otro.duracionMin,
      otroSinDatos,
    };
  });
  comparativaRows.sort((a, b) => a.diaOrden - b.diaOrden || (b.noTotal ?? 0) - (a.noTotal ?? 0));
}

const title       = `Análisis · Semana Santa de Sevilla ${anio} | Open Data`;
const description = `Análisis cruzado de nazarenos y horarios de la Semana Santa de Sevilla ${anio}: duración, composición del cortejo, nazarenos en la calle y densidad del desfile.`;

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Dataset',
  name: `Análisis cruzado Semana Santa de Sevilla ${anio}`,
  description,
  url: new URL(`/${anio}/analisis/`, Astro.site).href,
  inLanguage: 'es',
  isPartOf: { '@type': 'Dataset', name: `Conteo de la Semana Santa de Sevilla ${anio}`, url: new URL(`/${anio}/`, Astro.site).href },
  temporalCoverage: anio,
  spatialCoverage: { '@type': 'Place', name: 'Sevilla, España' },
  isAccessibleForFree: true,
};
---

<Base title={title} description={description} jsonLd={jsonLd} anioActivo={anioNum}>
  <section class="anio-cab contenedor">
    <div class="anio-cab__top">
      <div>
        <h1 class="anio-cab__titulo"><a href={`/${anio}/`}>{anio}</a> — Análisis</h1>
        {sinDatos.length > 0 && (
          <p class="nota-aviso" style="margin-top:0.5rem">
            <strong>{sinDatos.length} hermandad{sinDatos.length > 1 ? 'es' : ''} sin datos</strong> ese año (posible lluvia o suspensión).
          </p>
        )}
      </div>
      <div class="anio-cab__kpis">
        <span class="kpi-mini"><strong>{fmt(conDatos.length)}</strong> cofradías</span>
        <span class="kpi-mini">media <strong>{fmtDur(durMedia)}</strong></span>
      </div>
    </div>
    <div class="anio-cab__links">
      <a href={`/${anio}/`}>Nazarenos</a>
      <a href={`/${anio}/horarios/`}>Horarios</a>
      <a href={`/${anio}/analisis/`} class="activo">Análisis</a>
    </div>
  </section>

  <GraficasAnalisis
    registros={conDatos}
    sinDatos={sinDatos}
    porDia={porDia}
    dias={diasPresentes}
    comparativaRows={comparativaRows}
    comparativaAnio={comparativaAnio}
    anioActual={anioNum}
  />

  <section class="panel contenedor">
    <FuentesResumen fuentes={fuentesPagina} />
  </section>
</Base>

