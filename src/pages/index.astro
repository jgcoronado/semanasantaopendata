---
import Base from '../layouts/Base.astro';
import { anios, getAnio, fmt } from '../lib/datos.js';

const title = 'Semana Santa de Sevilla en datos abiertos: nazarenos por año, día y hermandad';
const description =
  'Datos abiertos del conteo oficial de la Semana Santa de Sevilla por año. Tablas y gráficas de ' +
  'nazarenos y participantes por hermandad y día, con comparativa entre años.';

const resumen = anios.map((a) => ({ ...a, datos: getAnio(a.anio).totalGeneral }));

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'Semana Santa Open Data',
  description,
  url: new URL('/', Astro.site).href,
  inLanguage: 'es',
};
---

<Base title={title} description={description} jsonLd={jsonLd}>
  <section class="hub contenedor">
    <h1 class="hub__titulo">Semana Santa de Sevilla — datos abiertos</h1>
    <div class="anios-grid">
      {resumen.map((a) => (
        <a class="anio-card" href={`/${a.slug}/`}>
          <span class="anio-card__anio">{a.anio}</span>
          <span class="anio-card__datos">
            <strong>{fmt(a.datos.noNaz)}</strong> nazarenos · {fmt(a.datos.noTotal)} en el cortejo
          </span>
          <span class="anio-card__meta">{fmt(a.datos.hermandades)} hermandades · {fmt(a.datos.dias)} días →</span>
        </a>
      ))}
      <a class="anio-card anio-card--cta" href="/comparativa/">
        <span class="anio-card__anio anio-card__anio--cta">↔</span>
        <span class="anio-card__datos">Comparativa entre años</span>
        <span class="anio-card__meta">Evolución por hermandad y día →</span>
      </a>
    </div>
  </section>
</Base>
