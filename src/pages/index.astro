---
import Base from '../layouts/Base.astro';
import { anios, getAnio, fmt } from '../lib/datos.js';

const title = 'Semana Santa de Sevilla en datos abiertos: nazarenos por año, día y hermandad';
const description =
  'Datos abiertos del conteo oficial de la Semana Santa de Sevilla por año. Tablas y gráficas de ' +
  'nazarenos y participantes por hermandad y día, con comparativa entre años.';

const resumen = anios.map((a) => ({ ...a, datos: getAnio(a.anio).totalGeneral }));

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'Semana Santa Open Data',
  description,
  url: new URL('/', Astro.site).href,
  inLanguage: 'es',
};
---

<Base title={title} description={description} jsonLd={jsonLd}>
  <section class="hero">
    <div class="contenedor">
      <h1>La Semana Santa de Sevilla, en datos abiertos</h1>
      <p class="nota-aviso" style="border-color:#b5462f;background:#fdecec;color:#7a2e1c;">
        🧪 Estás viendo el <strong>entorno de PRUEBAS</strong> (rama <code>pre</code>). Esto no es
        la web pública.
      </p>
      <p>
        El conteo oficial de nazarenos y participantes de cada cofradía, año a año. Consulta las
        tablas y gráficas por día y por hermandad, descarga los datos y compara la evolución entre
        años.
      </p>
    </div>
  </section>

  <section class="panel contenedor">
    <div class="panel__cab"><h2>Elige un año</h2></div>
    <div class="anios-grid">
      {resumen.map((a) => (
        <a class="anio-card" href={`/${a.slug}/`}>
          <span class="anio-card__anio">{a.anio}</span>
          <span class="anio-card__datos">
            <strong>{fmt(a.datos.noNaz)}</strong> nazarenos · {fmt(a.datos.noTotal)} en el cortejo
          </span>
          <span class="anio-card__meta">{fmt(a.datos.hermandades)} hermandades · {fmt(a.datos.dias)} días con conteo →</span>
        </a>
      ))}
    </div>
  </section>

  <section class="panel contenedor">
    <div class="comparativa-cta">
      <div>
        <h2>Comparativa entre años</h2>
        <p>Evolución del número de nazarenos y del cortejo por hermandad y por día.</p>
      </div>
      <a class="btn" href="/comparativa/">Ver comparativa →</a>
    </div>
  </section>
</Base>
